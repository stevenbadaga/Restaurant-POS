# ==========================================
# Restaurant POS — Test Environment Configuration
# ==========================================
# Copy this file to .env.test and fill in your values.
# IMPORTANT: Never point DATABASE_URL_TEST at your development or production database.
# The test database name MUST contain a clear "test" indicator.
# This file is safe to commit to version control (all values are placeholders).
# ==========================================

# --- Test Database ---
# This must be a SEPARATE database from your development database.
# The name must contain "test" to confirm it is a disposable database.
DATABASE_URL_TEST="postgresql://postgres:YOUR_PASSWORD@localhost:5432/restaurant_pos_test"

# --- Test Application ---
NODE_ENV="test"
PORT=5001
CLIENT_URL="http://localhost:5173"

# --- JWT Secrets (test only - use fresh secrets in production) ---
JWT_ACCESS_SECRET="test-access-secret-min-16-chars-long"
JWT_REFRESH_SECRET="test-refresh-secret-min-16-chars-long"

# --- Test Settings ---
COOKIE_SECURE="false"
LOG_LEVEL="silent"
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=100
