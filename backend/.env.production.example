# ==========================================
# Restaurant POS — Server Production Configuration
# ==========================================
# Copy this file to .env and fill in your production values.
# All production secrets must be generated fresh and never reused from development.
# This file is safe to commit to version control (all values are placeholders).
# ==========================================

# --- Application ---
NODE_ENV="production"
PORT=5000

# --- Database ---
# PostgreSQL connection string. Use a strong user password.
# Never reuse your development database password in production.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:YOUR_PRODUCTION_PASSWORD@localhost:5432/restaurant_pos"

# --- Client URL ---
# Comma-separated list of allowed origins for CORS.
# Example: CLIENT_URL="https://pos.yourdomain.com"
CLIENT_URL="https://pos.yourdomain.com"

# ALLOWED_ORIGINS is derived from CLIENT_URL. Add additional origins as needed.
# Example: ALLOWED_ORIGINS="https://pos.yourdomain.com,https://admin.yourdomain.com"

# --- JWT Secrets ---
# Generate using: openssl rand -hex 64
# Never reuse development secrets in production.
JWT_ACCESS_SECRET="generate-a-64-char-hex-string"
JWT_REFRESH_SECRET="generate-another-64-char-hex-string"

# --- Token Expiry ---
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# --- Cookies ---
# Secure cookies require HTTPS. Must be true in production.
COOKIE_SECURE="true"
# Set your production domain if needed (omit for same-domain deployment)
# COOKIE_DOMAIN=".yourdomain.com"

# --- Security ---
# Set TRUST_PROXY=true when behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY="true"

# --- Rate Limiting ---
# General API rate limit window (ms) and max requests
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Stricter limit for auth endpoints (login, refresh)
AUTH_RATE_LIMIT_MAX=10

# --- Logging ---
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL="info"

# --- Database ---
# Connection pool size (adjust based on server resources)
DATABASE_POOL_SIZE=10

# --- File Paths ---
# Directory for database backups
BACKUP_DIRECTORY="./backups"
# Temporary directory for PDF generation
PDF_TEMP_DIRECTORY="./temp"

# --- Maintenance ---
# Set to true during planned maintenance periods
MAINTENANCE_MODE="false"
# Optional maintenance message shown to users
# MAINTENANCE_MESSAGE="System is undergoing scheduled maintenance. Please check back shortly."
