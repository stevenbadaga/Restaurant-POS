// --- MODELS ---

model EmployeeEmploymentProfile {
  id                    String           @id @default(uuid())
  restaurantId          String
  userId                String
  employeeCodeSnapshot  String
  employmentType        EmploymentType
  employmentStatus      EmploymentStatus @default(ACTIVE)
  jobTitle              String?
  department            String?
  hireDate              DateTime
  contractStartDate     DateTime?
  contractEndDate       DateTime?
  probationEndDate      DateTime?
  terminationDate       DateTime?
  terminationReason     String?
  standardHoursPerWeek  Float?
  standardDaysPerWeek   Int?
  defaultPayFrequency   PayFrequency     @default(MONTHLY)
  primaryPayBasis       PayBasis         @default(MONTHLY_SALARY)
  payrollEligible       Boolean          @default(true)
  leaveEligible         Boolean          @default(true)
  overtimeEligible      Boolean          @default(true)
  tipEligible           Boolean          @default(true)
  serviceChargeEligible Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, userId])
  @@index([restaurantId])
  @@index([employmentStatus])
  @@index([employmentType])
  @@index([payrollEligible])
  @@index([hireDate])
}

model EmployeeCompensationProfile {
  id                           String       @id @default(uuid())
  restaurantId                 String
  userId                       String
  employmentProfileId          String
  effectiveFrom                DateTime
  effectiveTo                  DateTime?
  payBasis                     PayBasis
  payFrequency                 PayFrequency
  baseSalary                   Decimal?
  hourlyRate                   Decimal?
  dailyRate                    Decimal?
  fixedPeriodAmount            Decimal?
  overtimeRateMultiplier       Decimal      @default(1.5)
  currency                     String       @default("RWF")
  standardHoursPerDay          Decimal?
  standardWorkingDaysPerPeriod Int?
  notes                        String?
  createdById                  String
  approvedById                 String?
  approvedAt                   DateTime?
  isActive                     Boolean      @default(true)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt

  user       User       @relation("compensationUser", fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  createdBy  User       @relation("compensationCreatedBy", fields: [createdById], references: [id])
  approvedBy User?      @relation("compensationApprovedBy", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([effectiveFrom])
  @@index([effectiveTo])
  @@index([isActive])
}

model LeaveType {
  id                      String        @id @default(uuid())
  restaurantId            String
  code                    String
  name                    String
  description             String?
  leaveTypeCode           LeaveTypeCode
  unit                    LeaveUnit     @default(DAYS)
  isPaid                  Boolean       @default(true)
  requiresAttachment      Boolean       @default(false)
  requiresApproval        Boolean       @default(true)
  allowsNegativeBalance   Boolean       @default(false)
  maximumNegativeBalance  Decimal       @default(0)
  minimumNoticeDays       Int           @default(0)
  maximumConsecutiveUnits Decimal?
  allowHalfDay            Boolean       @default(true)
  allowHourlyRequest      Boolean       @default(false)
  colorKey                String?
  isActive                Boolean       @default(true)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  restaurant              Restaurant               @relation(fields: [restaurantId], references: [id])
  leaveRequests           LeaveRequest[]
  leaveLedgerTransactions LeaveLedgerTransaction[]
  employeeLeaveBalances   EmployeeLeaveBalance[]
  leavePolicies           LeavePolicy[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([isActive])
  @@index([leaveTypeCode])
}

model LeavePolicy {
  id                           String                 @id @default(uuid())
  restaurantId                 String
  name                         String
  leaveTypeId                  String
  employmentType               EmploymentType?
  annualEntitlement            Decimal
  accrualEnabled               Boolean                @default(false)
  accrualFrequency             LeaveAccrualFrequency?
  accrualAmount                Decimal?
  carryForwardEnabled          Boolean                @default(false)
  maximumCarryForward          Decimal?
  expiryMonths                 Int?
  waitingPeriodDays            Int                    @default(0)
  prorateForNewEmployee        Boolean                @default(true)
  prorateForTerminatedEmployee Boolean                @default(true)
  isActive                     Boolean                @default(true)
  effectiveFrom                DateTime
  effectiveTo                  DateTime?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt

  leaveType  LeaveType  @relation(fields: [leaveTypeId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([leaveTypeId])
  @@index([employmentType])
  @@index([effectiveFrom])
  @@index([isActive])
}

model EmployeeLeaveBalance {
  id               String   @id @default(uuid())
  restaurantId     String
  userId           String
  leaveTypeId      String
  balanceYear      Int
  openingBalance   Decimal  @default(0)
  accrued          Decimal  @default(0)
  used             Decimal  @default(0)
  reserved         Decimal  @default(0)
  expired          Decimal  @default(0)
  adjusted         Decimal  @default(0)
  availableBalance Decimal  @default(0)
  lastCalculatedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                    User                     @relation(fields: [userId], references: [id])
  leaveType               LeaveType                @relation(fields: [leaveTypeId], references: [id])
  restaurant              Restaurant               @relation(fields: [restaurantId], references: [id])
  leaveLedgerTransactions LeaveLedgerTransaction[]

  @@unique([restaurantId, userId, leaveTypeId, balanceYear])
  @@index([userId])
  @@index([leaveTypeId])
  @@index([balanceYear])
}

model LeaveLedgerTransaction {
  id                  String                     @id @default(uuid())
  restaurantId        String
  userId              String
  leaveTypeId         String
  leaveBalanceId      String
  transactionType     LeaveLedgerTransactionType
  quantity            Decimal
  balanceBefore       Decimal
  balanceAfter        Decimal
  leaveRequestId      String?
  reason              String?
  effectiveDate       DateTime
  createdById         String
  parentTransactionId String?
  createdAt           DateTime                   @default(now())

  user         User                 @relation(fields: [userId], references: [id])
  leaveType    LeaveType            @relation(fields: [leaveTypeId], references: [id])
  leaveBalance EmployeeLeaveBalance @relation(fields: [leaveBalanceId], references: [id])
  leaveRequest LeaveRequest?        @relation(fields: [leaveRequestId], references: [id])
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id])
  createdBy    User                 @relation("ledgerCreatedBy", fields: [createdById], references: [id])

  @@index([userId])
  @@index([leaveTypeId])
  @@index([leaveRequestId])
  @@index([effectiveDate])
  @@index([transactionType])
}

model LeaveRequest {
  id                  String             @id @default(uuid())
  restaurantId        String
  leaveRequestNumber  String
  userId              String
  leaveTypeId         String
  status              LeaveRequestStatus @default(DRAFT)
  startDate           DateTime
  endDate             DateTime
  startHalfDay        Boolean            @default(false)
  endHalfDay          Boolean            @default(false)
  startTime           String?
  endTime             String?
  requestedQuantity   Decimal
  approvedQuantity    Decimal?
  reason              String
  employeeNotes       String?
  managerNotes        String?
  attachmentReference String?
  submittedAt         DateTime?
  approvedAt          DateTime?
  approvedById        String?
  rejectedAt          DateTime?
  rejectedById        String?
  rejectionReason     String?
  cancelledAt         DateTime?
  cancelledById       String?
  cancellationReason  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  leaveType      LeaveType       @relation(fields: [leaveTypeId], references: [id])
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  approvedBy     User?           @relation("leaveApprovedBy", fields: [approvedById], references: [id])
  rejectedBy     User?           @relation("leaveRejectedBy", fields: [rejectedById], references: [id])
  cancelledBy    User?           @relation("leaveCancelledBy", fields: [cancelledById], references: [id])
  leaveApprovals LeaveApproval[]

  leaveLedgerTransactions LeaveLedgerTransaction[]

  @@unique([restaurantId, leaveRequestNumber])
  @@index([userId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model LeaveApproval {
  id               String             @id @default(uuid())
  restaurantId     String
  leaveRequestId   String
  status           LeaveRequestStatus
  requestedById    String
  requestedAt      DateTime?
  reviewedById     String?
  reviewedAt       DateTime?
  approvedQuantity Decimal?
  reason           String?
  createdAt        DateTime           @default(now())

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  requestedBy  User         @relation("leaveApprovalRequestedBy", fields: [requestedById], references: [id])
  reviewedBy   User?        @relation("leaveApprovalReviewedBy", fields: [reviewedById], references: [id])

  userLeaveApproval User[] @relation("userLeaveApproval")

  @@index([leaveRequestId])
  @@index([status])
  @@index([reviewedById])
}

model OvertimeApproval {
  id                String                 @id @default(uuid())
  restaurantId      String
  userId            String
  shiftAssignmentId String?
  overtimeMinutes   Int
  status            OvertimeApprovalStatus @default(PENDING)
  reason            String?
  requestedById     String
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime               @default(now())

  user        User       @relation(fields: [userId], references: [id])
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  requestedBy User       @relation("overtimeRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?      @relation("overtimeReviewedBy", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
}

model PayrollPeriod {
  id           String              @id @default(uuid())
  restaurantId String
  periodNumber String
  name         String
  startDate    DateTime
  endDate      DateTime
  payDate      DateTime?
  payFrequency PayFrequency
  status       PayrollPeriodStatus @default(DRAFT)
  currency     String              @default("RWF")
  notes        String?
  openedAt     DateTime?
  openedById   String?
  closedAt     DateTime?
  closedById   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id])
  payrollRuns PayrollRun[]

  @@unique([restaurantId, periodNumber])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
  @@index([payFrequency])
}

model PayrollComponentDefinition {
  id                String                   @id @default(uuid())
  restaurantId      String
  code              String
  name              String
  description       String?
  componentType     PayrollComponentType
  calculationMethod PayrollCalculationMethod
  defaultAmount     Decimal?
  defaultPercentage Decimal?
  defaultRate       Decimal?
  taxable           Boolean                  @default(false)
  pensionable       Boolean                  @default(false)
  affectsGrossPay   Boolean                  @default(true)
  affectsNetPay     Boolean                  @default(true)
  employerOnly      Boolean                  @default(false)
  recurring         Boolean                  @default(false)
  displayOnPayslip  Boolean                  @default(true)
  displayOrder      Int                      @default(0)
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  restaurant                         Restaurant                          @relation(fields: [restaurantId], references: [id])
  employeeRecurringPayrollComponents EmployeeRecurringPayrollComponent[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([componentType])
  @@index([isActive])
}

model EmployeeRecurringPayrollComponent {
  id                           String    @id @default(uuid())
  restaurantId                 String
  userId                       String
  payrollComponentDefinitionId String
  effectiveFrom                DateTime
  effectiveTo                  DateTime?
  amount                       Decimal?
  percentage                   Decimal?
  rate                         Decimal?
  notes                        String?
  isActive                     Boolean   @default(true)
  createdById                  String
  approvedById                 String?
  approvedAt                   DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  user                       User                       @relation(fields: [userId], references: [id])
  payrollComponentDefinition PayrollComponentDefinition @relation(fields: [payrollComponentDefinitionId], references: [id])
  restaurant                 Restaurant                 @relation(fields: [restaurantId], references: [id])
  createdBy                  User                       @relation("recurringComponentCreatedBy", fields: [createdById], references: [id])

  @@index([userId])
  @@index([payrollComponentDefinitionId])
  @@index([effectiveFrom])
  @@index([isActive])
}

model PayrollRun {
  id                         String           @id @default(uuid())
  restaurantId               String
  payrollRunNumber           String
  payrollPeriodId            String
  status                     PayrollRunStatus @default(DRAFT)
  currency                   String           @default("RWF")
  employeeCount              Int              @default(0)
  totalBasePay               Decimal          @default(0)
  totalOvertime              Decimal          @default(0)
  totalAllowances            Decimal          @default(0)
  totalBonuses               Decimal          @default(0)
  totalTips                  Decimal          @default(0)
  totalServiceCharge         Decimal          @default(0)
  totalGrossEarnings         Decimal          @default(0)
  totalEmployeeDeductions    Decimal          @default(0)
  totalEmployerContributions Decimal          @default(0)
  totalAdvanceRepayments     Decimal          @default(0)
  totalNetPay                Decimal          @default(0)
  totalAmountPaid            Decimal          @default(0)
  totalAmountDue             Decimal          @default(0)
  calculatedAt               DateTime?
  calculatedById             String?
  submittedAt                DateTime?
  approvedAt                 DateTime?
  approvedById               String?
  finalizedAt                DateTime?
  finalizedById              String?
  cancelledAt                DateTime?
  cancelledById              String?
  cancellationReason         String?
  notes                      String?
  createdById                String
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  createdBy     User          @relation("payrollRunCreatedBy", fields: [createdById], references: [id])
  calculatedBy  User?         @relation("payrollRunCalculatedBy", fields: [calculatedById], references: [id])
  approvedBy    User?         @relation("payrollRunApprovedBy", fields: [approvedById], references: [id])
  finalizedBy   User?         @relation("payrollRunFinalizedBy", fields: [finalizedById], references: [id])

  employeeLines PayrollEmployeeLine[]
  approvals     PayrollApproval[]
  disbursements PayrollDisbursement[]
  payslips      Payslip[]

  userPayrollRun  User[]              @relation("userPayrollRun")
  tipPoolPostings TipPool[]           @relation("tipPoolPostedToPayroll")
  scPoolPostings  ServiceChargePool[] @relation("scPoolPostedToPayroll")

  @@unique([restaurantId, payrollRunNumber])
  @@index([payrollPeriodId])
  @@index([status])
  @@index([createdAt])
}

model PayrollEmployeeLine {
  id                        String                    @id @default(uuid())
  restaurantId              String
  payrollRunId              String
  userId                    String
  employeeCodeSnapshot      String
  employeeNameSnapshot      String
  jobTitleSnapshot          String?
  employmentTypeSnapshot    String
  payBasisSnapshot          String
  compensationEffectiveDate DateTime?
  baseRateSnapshot          Decimal?
  standardHours             Decimal?
  workedHours               Decimal?
  paidLeaveHours            Decimal?
  unpaidLeaveHours          Decimal?
  overtimeHours             Decimal?
  basePay                   Decimal?
  overtimePay               Decimal?
  allowanceTotal            Decimal?
  bonusTotal                Decimal?
  tipTotal                  Decimal?
  serviceChargeTotal        Decimal?
  grossEarnings             Decimal?
  employeeDeductionTotal    Decimal?
  employerContributionTotal Decimal?
  advanceRepaymentTotal     Decimal?
  netPay                    Decimal?
  amountPaid                Decimal                   @default(0)
  amountDue                 Decimal?
  status                    PayrollEmployeeLineStatus @default(DRAFT)
  reviewReason              String?
  approvedAt                DateTime?
  approvedById              String?
  finalizedAt               DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  approvedBy User?      @relation("payrollLineApprovedBy", fields: [approvedById], references: [id])

  lineItems            PayrollLineItem[]
  advanceRepayments    StaffAdvanceRepayment[]
  payslips             Payslip[]
  payrollDisbursements PayrollDisbursement[]

  @@unique([payrollRunId, userId])
  @@index([payrollRunId])
  @@index([userId])
  @@index([status])
}

model PayrollLineItem {
  id                           String                    @id @default(uuid())
  restaurantId                 String
  payrollEmployeeLineId        String
  payrollComponentDefinitionId String?
  componentCodeSnapshot        String
  componentNameSnapshot        String
  componentType                PayrollComponentType
  calculationMethodSnapshot    String
  quantity                     Decimal?
  rate                         Decimal?
  percentage                   Decimal?
  amount                       Decimal
  sourceType                   PayrollLineItemSourceType
  sourceId                     String?
  description                  String?
  isEmployerOnly               Boolean                   @default(false)
  displayOnPayslip             Boolean                   @default(true)
  createdAt                    DateTime                  @default(now())

  payrollEmployeeLine PayrollEmployeeLine @relation(fields: [payrollEmployeeLineId], references: [id], onDelete: Cascade)
  restaurant          Restaurant          @relation(fields: [restaurantId], references: [id])

  @@index([payrollEmployeeLineId])
  @@index([componentType])
}

model PayrollApproval {
  id            String                @id @default(uuid())
  restaurantId  String
  payrollRunId  String
  status        PayrollApprovalStatus @default(PENDING)
  requestedById String
  requestedAt   DateTime?
  reviewedById  String?
  reviewedAt    DateTime?
  reason        String?
  createdAt     DateTime              @default(now())

  payrollRun  PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  requestedBy User       @relation("payrollApprovalRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?      @relation("payrollApprovalReviewedBy", fields: [reviewedById], references: [id])

  userPayrollApproval User[] @relation("userPayrollApproval")

  @@index([payrollRunId])
  @@index([status])
}

model PayrollDisbursement {
  id                        String                    @id @default(uuid())
  restaurantId              String
  payrollDisbursementNumber String
  payrollRunId              String
  payrollEmployeeLineId     String
  userId                    String
  paymentDate               DateTime
  paymentMethod             PayrollPaymentMethod
  status                    PayrollDisbursementStatus @default(DRAFT)
  amount                    Decimal
  referenceNumber           String?
  providerName              String?
  cashierSessionId          String?
  notes                     String?
  idempotencyKey            String?
  postedById                String?
  postedAt                  DateTime?
  reversedById              String?
  reversedAt                DateTime?
  reversalReason            String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  payrollRun          PayrollRun          @relation(fields: [payrollRunId], references: [id])
  payrollEmployeeLine PayrollEmployeeLine @relation(fields: [payrollEmployeeLineId], references: [id])
  user                User                @relation(fields: [userId], references: [id])
  restaurant          Restaurant          @relation(fields: [restaurantId], references: [id])
  postedBy            User?               @relation("disbursementPostedBy", fields: [postedById], references: [id])
  reversedBy          User?               @relation("disbursementReversedBy", fields: [reversedById], references: [id])

  @@unique([restaurantId, payrollDisbursementNumber])
  @@index([payrollRunId])
  @@index([payrollEmployeeLineId])
  @@index([userId])
  @@index([status])
  @@index([paymentDate])
}

model Payslip {
  id                            String        @id @default(uuid())
  restaurantId                  String
  payslipNumber                 String
  payrollRunId                  String
  payrollEmployeeLineId         String
  userId                        String
  status                        PayslipStatus @default(ISSUED)
  employeeSnapshot              Json
  earningsSnapshot              Json
  deductionsSnapshot            Json
  employerContributionsSnapshot Json?
  summarySnapshot               Json
  issuedAt                      DateTime      @default(now())
  issuedById                    String
  voidedAt                      DateTime?
  voidedById                    String?
  voidReason                    String?
  replacedByPayslipId           String?
  createdAt                     DateTime      @default(now())

  payrollRun          PayrollRun          @relation(fields: [payrollRunId], references: [id])
  payrollEmployeeLine PayrollEmployeeLine @relation(fields: [payrollEmployeeLineId], references: [id])
  user                User                @relation(fields: [userId], references: [id])
  restaurant          Restaurant          @relation(fields: [restaurantId], references: [id])
  issuedBy            User                @relation("payslipIssuedBy", fields: [issuedById], references: [id])
  voidedBy            User?               @relation("payslipVoidedBy", fields: [voidedById], references: [id])

  @@unique([restaurantId, payslipNumber])
  @@index([payrollRunId])
  @@index([userId])
  @@index([status])
  @@index([issuedAt])
}

model StaffAdvance {
  id                                String             @id @default(uuid())
  restaurantId                      String
  advanceNumber                     String
  userId                            String
  requestDate                       DateTime
  requestedAmount                   Decimal
  approvedAmount                    Decimal?
  disbursedAmount                   Decimal            @default(0)
  repaidAmount                      Decimal            @default(0)
  outstandingAmount                 Decimal            @default(0)
  currency                          String             @default("RWF")
  status                            StaffAdvanceStatus @default(DRAFT)
  reason                            String
  requestedRepaymentAmountPerPeriod Decimal?
  approvedRepaymentAmountPerPeriod  Decimal?
  plannedStartPeriodId              String?
  requestedById                     String
  submittedAt                       DateTime?
  approvedAt                        DateTime?
  approvedById                      String?
  rejectedAt                        DateTime?
  rejectedById                      String?
  rejectionReason                   String?
  disbursedAt                       DateTime?
  disbursedById                     String?
  paymentMethod                     String?
  paymentReference                  String?
  cashierSessionId                  String?
  writtenOffAt                      DateTime?
  writtenOffById                    String?
  writeOffReason                    String?
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime           @updatedAt

  user         User       @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  requestedBy  User       @relation("advanceRequestedBy", fields: [requestedById], references: [id])
  approvedBy   User?      @relation("advanceApprovedBy", fields: [approvedById], references: [id])
  rejectedBy   User?      @relation("advanceRejectedBy", fields: [rejectedById], references: [id])
  disbursedBy  User?      @relation("advanceDisbursedBy", fields: [disbursedById], references: [id])
  writtenOffBy User?      @relation("advanceWrittenOffBy", fields: [writtenOffById], references: [id])

  repayments StaffAdvanceRepayment[]

  @@unique([restaurantId, advanceNumber])
  @@index([userId])
  @@index([status])
  @@index([requestDate])
}

model StaffAdvanceRepayment {
  id                    String                      @id @default(uuid())
  restaurantId          String
  staffAdvanceId        String
  userId                String
  repaymentDate         DateTime
  repaymentMethod       StaffAdvanceRepaymentMethod
  amount                Decimal
  payrollEmployeeLineId String?
  cashierSessionId      String?
  referenceNumber       String?
  status                AdvanceRepaymentStatus      @default(POSTED)
  recordedById          String
  reversedAt            DateTime?
  reversedById          String?
  reversalReason        String?
  createdAt             DateTime                    @default(now())

  staffAdvance        StaffAdvance         @relation(fields: [staffAdvanceId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  payrollEmployeeLine PayrollEmployeeLine? @relation(fields: [payrollEmployeeLineId], references: [id])
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id])
  recordedBy          User                 @relation("repaymentRecordedBy", fields: [recordedById], references: [id])
  reversedBy          User?                @relation("repaymentReversedBy", fields: [reversedById], references: [id])

  @@index([staffAdvanceId])
  @@index([userId])
  @@index([payrollEmployeeLineId])
  @@index([repaymentDate])
}

model CustomerTip {
  id                    String    @id @default(uuid())
  restaurantId          String
  tipNumber             String
  orderId               String
  paymentId             String?
  paymentMethod         String
  amount                Decimal
  status                TipStatus @default(RECORDED)
  directRecipientUserId String?
  tipPoolId             String?
  recordedById          String
  recordedAt            DateTime  @default(now())
  reversedAt            DateTime?
  reversedById          String?
  reversalReason        String?
  createdAt             DateTime  @default(now())

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  recordedBy      User       @relation("tipRecordedBy", fields: [recordedById], references: [id])
  reversedBy      User?      @relation("tipReversedBy", fields: [reversedById], references: [id])
  directRecipient User?      @relation("tipDirectRecipient", fields: [directRecipientUserId], references: [id])

  userCustomerTip User[] @relation("userCustomerTip")

  @@unique([restaurantId, tipNumber])
  @@index([orderId])
  @@index([paymentId])
  @@index([directRecipientUserId])
  @@index([status])
  @@index([recordedAt])
}

model TipPool {
  id                     String                 @id @default(uuid())
  restaurantId           String
  tipPoolNumber          String
  name                   String
  startDate              DateTime
  endDate                DateTime
  allocationMethod       TipAllocationMethod
  status                 DistributionPoolStatus @default(DRAFT)
  totalTipAmount         Decimal                @default(0)
  distributableAmount    Decimal                @default(0)
  undistributedAmount    Decimal                @default(0)
  includedPaymentMethods Json?
  eligibleRoles          Json?
  notes                  String?
  calculatedAt           DateTime?
  calculatedById         String?
  approvedAt             DateTime?
  approvedById           String?
  postedToPayrollRunId   String?
  createdById            String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  createdBy       User        @relation("tipPoolCreatedBy", fields: [createdById], references: [id])
  calculatedBy    User?       @relation("tipPoolCalculatedBy", fields: [calculatedById], references: [id])
  approvedBy      User?       @relation("tipPoolApprovedBy", fields: [approvedById], references: [id])
  postedToPayroll PayrollRun? @relation("tipPoolPostedToPayroll", fields: [postedToPayrollRunId], references: [id])

  allocations TipPoolAllocation[]

  userTipPool User[] @relation("userTipPool")

  @@unique([restaurantId, tipPoolNumber])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
  @@index([postedToPayrollRunId])
}

model TipPoolAllocation {
  id                    String                       @id @default(uuid())
  restaurantId          String
  tipPoolId             String
  userId                String
  allocationBasis       String
  basisValue            Decimal?
  allocationPercentage  Decimal?
  allocatedAmount       Decimal
  payrollEmployeeLineId String?
  status                DistributionAllocationStatus @default(CALCULATED)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  tipPool    TipPool    @relation(fields: [tipPoolId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([tipPoolId, userId])
  @@index([tipPoolId])
  @@index([userId])
  @@index([status])
}

model ServiceChargePool {
  id                          String                          @id @default(uuid())
  restaurantId                String
  serviceChargePoolNumber     String
  name                        String
  startDate                   DateTime
  endDate                     DateTime
  distributionMethod          ServiceChargeDistributionMethod
  status                      DistributionPoolStatus          @default(DRAFT)
  totalServiceChargeCollected Decimal                         @default(0)
  restaurantRetainedAmount    Decimal                         @default(0)
  distributableAmount         Decimal                         @default(0)
  undistributedAmount         Decimal                         @default(0)
  eligibleRoles               Json?
  notes                       String?
  calculationBasis            String                          @default("CASH_COLLECTED")
  calculatedAt                DateTime?
  calculatedById              String?
  approvedAt                  DateTime?
  approvedById                String?
  postedToPayrollRunId        String?
  createdById                 String
  createdAt                   DateTime                        @default(now())
  updatedAt                   DateTime                        @updatedAt

  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  createdBy       User        @relation("scPoolCreatedBy", fields: [createdById], references: [id])
  calculatedBy    User?       @relation("scPoolCalculatedBy", fields: [calculatedById], references: [id])
  approvedBy      User?       @relation("scPoolApprovedBy", fields: [approvedById], references: [id])
  postedToPayroll PayrollRun? @relation("scPoolPostedToPayroll", fields: [postedToPayrollRunId], references: [id])

  allocations ServiceChargeAllocation[]

  userServiceChargePool User[] @relation("userServiceChargePool")

  @@unique([restaurantId, serviceChargePoolNumber])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
  @@index([postedToPayrollRunId])
}

model ServiceChargeAllocation {
  id                    String                       @id @default(uuid())
  restaurantId          String
  serviceChargePoolId   String
  userId                String
  allocationBasis       String
  basisValue            Decimal?
  allocationPercentage  Decimal?
  allocatedAmount       Decimal
  payrollEmployeeLineId String?
  status                DistributionAllocationStatus @default(CALCULATED)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  serviceChargePool ServiceChargePool @relation(fields: [serviceChargePoolId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id])
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])

  @@unique([serviceChargePoolId, userId])
  @@index([serviceChargePoolId])
  @@index([userId])
  @@index([status])
}

model PayrollSettings {
  id                                          String                           @id @default(uuid())
  restaurantId                                String                           @unique
  payrollEnabled                              Boolean                          @default(false)
  defaultPayFrequency                         PayFrequency                     @default(MONTHLY)
  payrollCurrency                             String                           @default("RWF")
  payrollPeriodStartDay                       Int                              @default(1)
  requirePayrollApproval                      Boolean                          @default(true)
  preventPayrollSelfApproval                  Boolean                          @default(true)
  requireEmployeeLineApproval                 Boolean                          @default(false)
  attendanceRequiredForHourlyPayroll          Boolean                          @default(true)
  approvedAttendanceOnly                      Boolean                          @default(true)
  overtimeEnabled                             Boolean                          @default(true)
  overtimeRequiresApproval                    Boolean                          @default(true)
  overtimeRoundingMinutes                     Int                              @default(15)
  allowNegativeNetPay                         Boolean                          @default(false)
  cashPayrollRequiresCashierSession           Boolean                          @default(true)
  leaveAccrualEnabled                         Boolean                          @default(false)
  tipsEnabled                                 Boolean                          @default(false)
  tipPoolingEnabled                           Boolean                          @default(false)
  serviceChargeDistributionEnabled            Boolean                          @default(false)
  serviceChargeEmployeeDistributionPercentage Decimal?                         @default(0)
  defaultTipAllocationMethod                  TipAllocationMethod?
  defaultServiceChargeDistributionMethod      ServiceChargeDistributionMethod?
  advanceRepaymentEnabled                     Boolean                          @default(true)
  maximumAdvancePercentageOfBasePay           Decimal                          @default(50)
  payslipEnabled                              Boolean                          @default(true)
  payslipPaperSize                            String                           @default("A4")
  payslipShowEmployerContributions            Boolean                          @default(true)
  statutoryCalculationMode                    StatutoryCalculationMode         @default(MANUAL_CONFIGURATION)
  createdAt                                   DateTime                         @default(now())
  updatedAt                                   DateTime                         @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

// ==========================================
// PRINTING INFRASTRUCTURE
// ==========================================

enum PrinterConnectionType {
  USB
  NETWORK
  BLUETOOTH
  BROWSER
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  ERROR
  DISABLED
}

enum PrintJobStatus {
  PENDING
  PRINTING
  COMPLETED
  FAILED
  CANCELLED
}

enum PrintJobType {
  RECEIPT
  KITCHEN_TICKET
  X_REPORT
  Z_REPORT
  ORDER_SUMMARY
  OTHER
}

model Printer {
  id              String                 @id @default(uuid())
  restaurantId    String
  name            String
  description     String?
  connectionType  PrinterConnectionType  @default(BROWSER)
  ipAddress       String?
  port            Int?
  paperSize       ReceiptPaperSize       @default(THERMAL_80MM)
  status          PrinterStatus          @default(ONLINE)
  isDefault       Boolean                @default(false)
  autoPrintReceipt Boolean               @default(false)
  autoPrintTicket Boolean                @default(false)
  kitchenStationId String?
  displayOrder    Int                    @default(0)
  isActive        Boolean                @default(true)
  config          Json?
  lastUsedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  kitchenStation KitchenStation?  @relation(fields: [kitchenStationId], references: [id])
  printJobs      PrintJob[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
  @@index([kitchenStationId])
}

model PrintJob {
  id            String         @id @default(uuid())
  restaurantId  String
  printerId     String?
  jobType       PrintJobType
  status        PrintJobStatus @default(PENDING)
  title         String
  content       String?
  contentType   String         @default("text/html")
  copies        Int            @default(1)
  paperSize     ReceiptPaperSize @default(THERMAL_80MM)
  entityType    String?
  entityId      String?
  orderId       String?
  ticketId      String?
  receiptId     String?
  requestedById String
  completedAt   DateTime?
  failedAt      DateTime?
  errorMessage  String?
  retryCount    Int            @default(0)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  printer    Printer?   @relation(fields: [printerId], references: [id])
  requestedBy User      @relation(fields: [requestedById], references: [id])

  @@index([restaurantId])
  @@index([printerId])
  @@index([orderId])
  @@index([ticketId])
  @@index([receiptId])
  @@index([status])
  @@index([createdAt])
}
