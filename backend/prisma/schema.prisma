// ==========================================
// BASE MODELS
// ==========================================

model Restaurant {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  address    String?
  currency   String   @default("RWF")
  timezone   String   @default("Africa/Kigali")
  logoUrl    String?
  publicSlug String?  @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users                        User[]
  auditLogs                    AuditLog[]
  settings                     RestaurantSettings?
  diningAreas                  DiningArea[]
  tables                       RestaurantTable[]
  menuCategories               MenuCategory[]
  menuItems                    MenuItem[]
  kitchenStations              KitchenStation[]
  orders                       Order[]
  payments                     Payment[]
  receipts                     Receipt[]
  paymentRequests              PaymentRequest[]
  refundRequests               RefundRequest[]
  stockLocations               StockLocation[]
  inventoryCategories          InventoryCategory[]
  inventoryItems               InventoryItem[]
  inventoryBalances            InventoryBalance[]
  suppliers                    Supplier[]
  stockReceipts                StockReceipt[]
  stockBatches                 StockBatch[]
  stockMovements               StockMovement[]
  stockReservations            StockReservation[]
  inventoryAlerts              InventoryAlert[]
  recipes                      Recipe[]
  menuItemInventoryLinks       MenuItemInventoryLink[]
  documentSequences            DocumentSequence[]
  refreshTokens                RefreshToken[]
  kitchenTickets               KitchenTicket[]
  notifications                AppNotification[]
  notificationPreferences      NotificationPreference[]
  approvalRequests             ApprovalRequest[]
  shiftTemplates               ShiftTemplate[]
  workShifts                   WorkShift[]
  shiftAssignments             ShiftAssignment[]
  attendanceEvents             AttendanceEvent[]
  employeeBreaks               EmployeeBreak[]
  cashRegisters                CashRegister[]
  cashierSessions              CashierSession[]
  cashDrawerMovements          CashDrawerMovement[]
  cashDenominationCounts       CashDenominationCount[]
  shiftHandovers               ShiftHandover[]
  shiftExceptions              ShiftException[]
  // Phase 8
  customers                    Customer[]
  customerNotes                CustomerNote[]
  reservations                 Reservation[]
  reservationStatusHistory     ReservationStatusHistory[]
  waitingListEntries           WaitingListEntry[]
  loyaltyAccounts              LoyaltyAccount[]
  loyaltyTransactions          LoyaltyTransaction[]
  promotions                   Promotion[]
  promotionUsages              PromotionUsage[]
  promotionMenuItems           PromotionMenuItem[]
  promotionMenuCategories      PromotionMenuCategory[]
  orderDiscounts               OrderDiscount[]
  discountRequests             DiscountRequest[]
  // Phase 9
  importJobs                   ImportJob[]                         @relation("importJobRestaurant")
  uatScenarios                 UATScenario[]                       @relation("uatRestaurant")
  // Phase 11: Procurement
  // Phase 10: Public website
  openingHours                 RestaurantOpeningHour[]
  openingHourPeriods           OpeningHourPeriod[]
  specialHours                 RestaurantSpecialHour[]
  deliveryZones                DeliveryZone[]
  customerAddresses            CustomerAddress[]
  tableQrTokens                TableQrToken[]
  publicOrderCancellations     PublicOrderCancellationRequest[]
  publicIdempotencyKeys        PublicOrderIdempotencyKey[]
  // Phase 12
  // Phase 12
  // Phase 13
  employeeLeaveBalances        EmployeeLeaveBalance[]
  leaveLedgerTransactions      LeaveLedgerTransaction[]
  leaveRequests                LeaveRequest[]
  leaveApprovals               LeaveApproval[]
  overtimeApprovals            OvertimeApproval[]
  payrollPeriods               PayrollPeriod[]
  payrollComponentDefinitions  PayrollComponentDefinition[]
  employeeRecurringComponents  EmployeeRecurringPayrollComponent[]
  payrollRuns                  PayrollRun[]
  payrollEmployeeLines         PayrollEmployeeLine[]
  payrollLineItems             PayrollLineItem[]
  payrollApprovals             PayrollApproval[]
  payrollDisbursements         PayrollDisbursement[]
  payslips                     Payslip[]
  staffAdvances                StaffAdvance[]
  staffAdvanceRepayments       StaffAdvanceRepayment[]
  customerTips                 CustomerTip[]
  tipPoolAllocations           TipPoolAllocation[]
  serviceChargePools           ServiceChargePool[]
  serviceChargeAllocations     ServiceChargeAllocation[]
  payrollSettings              PayrollSettings?
  leavePolicies                LeavePolicy[]
  leaveTypes                   LeaveType[]
  employeeCompensationProfiles EmployeeCompensationProfile[]
  employeeEmploymentProfiles   EmployeeEmploymentProfile[]
  tipPools                     TipPool[]
  printers                     Printer[]
  printJobs                    PrintJob[]
}

model RestaurantSettings {
  id                                        String                    @id @default(uuid())
  restaurantId                              String                    @unique
  defaultTaxRate                            Decimal                   @default(0)
  serviceChargeRate                         Decimal                   @default(0)
  pricesIncludeTax                          Boolean                   @default(false)
  allowNegativeStock                        Boolean                   @default(false)
  receiptFooter                             String?
  orderNumberPrefix                         String                    @default("ORD")
  receiptNumberPrefix                       String                    @default("REC")
  tableRequiredForDineIn                    Boolean                   @default(true)
  tableStatusAfterOrderClosure              TableStatus               @default(CLEANING)
  allowPartialPayments                      Boolean                   @default(true)
  allowSplitPayments                        Boolean                   @default(true)
  requireReferenceForCard                   Boolean                   @default(false)
  requireReferenceForMobileMoney            Boolean                   @default(true)
  requireReferenceForBankTransfer           Boolean                   @default(true)
  allowPaymentBeforeServing                 Boolean                   @default(false)
  printReceiptAutomatically                 Boolean                   @default(false)
  receiptPaperSize                          ReceiptPaperSize          @default(THERMAL_80MM)
  receiptShowCustomerPhone                  Boolean                   @default(false)
  receiptShowWaiter                         Boolean                   @default(true)
  receiptShowTaxBreakdown                   Boolean                   @default(true)
  businessDayStartTime                      String                    @default("00:00")
  // Shift & attendance settings
  requireClockInForOperationalActions       Boolean                   @default(false)
  requireOpenCashierSessionForCashPayments  Boolean                   @default(false)
  allowUnscheduledClockIn                   Boolean                   @default(true)
  allowEmployeeSelfClockIn                  Boolean                   @default(true)
  allowEmployeeSelfClockOut                 Boolean                   @default(true)
  cashVarianceApprovalThreshold             Decimal                   @default(0)
  cashVarianceWarningThreshold              Decimal                   @default(0)
  requireManagerApprovalForCashOut          Boolean                   @default(true)
  requireManagerApprovalForSafeDrop         Boolean                   @default(false)
  requireHandoverBeforeShiftClose           Boolean                   @default(false)
  autoCloseOpenBreakOnClockOut              Boolean                   @default(true)
  shiftClosingGraceMinutes                  Int                       @default(30)
  // Phase 8: Loyalty settings
  loyaltyEnabled                            Boolean                   @default(false)
  pointsPerCurrencyUnit                     Decimal                   @default(0)
  minimumSpendToEarnPoints                  Decimal                   @default(0)
  loyaltyRedemptionEnabled                  Boolean                   @default(false)
  currencyValuePerPoint                     Decimal                   @default(0)
  minimumPointsToRedeem                     Int                       @default(0)
  maximumRedemptionPercentage               Decimal                   @default(100)
  loyaltyPointsExpiryMonths                 Int?
  loyaltyPointsEarnOnDiscountedAmount       Boolean                   @default(true)
  loyaltyPointsEarnOnTax                    Boolean                   @default(false)
  loyaltyPointsEarnOnServiceCharge          Boolean                   @default(false)
  // Phase 8: Reservation settings
  reservationsEnabled                       Boolean                   @default(true)
  defaultReservationDurationMinutes         Int                       @default(120)
  reservationArrivalGraceMinutes            Int                       @default(15)
  reservationLateHoldingMinutes             Int                       @default(15)
  requirePhoneForReservation                Boolean                   @default(true)
  requireCustomerProfileForReservation      Boolean                   @default(false)
  allowTableOverbooking                     Boolean                   @default(false)
  allowReservationWithoutTable              Boolean                   @default(true)
  reservationReminderMinutes                Int?
  waitingListEnabled                        Boolean                   @default(true)
  defaultWaitingEstimateMinutes             Int                       @default(20)
  // Phase 8: Discount settings
  allowPromotionStacking                    Boolean                   @default(false)
  allowLoyaltyWithPromotions                Boolean                   @default(true)
  allowManualDiscountWithPromotions         Boolean                   @default(false)
  maximumTotalDiscountPercentage            Decimal                   @default(100)
  requireManagerApprovalForManualDiscount   Boolean                   @default(true)
  manualDiscountApprovalThresholdPercentage Decimal                   @default(10)
  // Phase 10: Public website & ordering settings
  publicWebsiteEnabled                      Boolean                   @default(false)
  publicOrderingEnabled                     Boolean                   @default(false)
  publicReservationsEnabled                 Boolean                   @default(false)
  qrTableOrderingEnabled                    Boolean                   @default(false)
  pickupEnabled                             Boolean                   @default(true)
  deliveryEnabled                           Boolean                   @default(false)
  dineInQrOrderingEnabled                   Boolean                   @default(false)
  publicRestaurantDescription               String?
  publicHeroImageUrl                        String?
  publicLogoUrl                             String?
  publicContactPhone                        String?
  publicContactEmail                        String?
  publicAddress                             String?
  publicMapUrl                              String?
  publicFacebookUrl                         String?
  publicInstagramUrl                        String?
  publicXUrl                                String?
  publicWhatsAppNumber                      String?
  publicMinimumOrderAmount                  Decimal                   @default(0)
  pickupPreparationMinutes                  Int                       @default(30)
  deliveryPreparationMinutes                Int                       @default(45)
  publicOrderAcceptanceMode                 PublicOrderAcceptanceMode @default(MANUAL)
  allowGuestCheckout                        Boolean                   @default(true)
  requirePhoneForPublicOrder                Boolean                   @default(true)
  requireEmailForPublicOrder                Boolean                   @default(false)
  publicOrderNotesEnabled                   Boolean                   @default(true)
  publicMenuShowPrices                      Boolean                   @default(true)
  publicMenuShowAvailability                Boolean                   @default(true)
  publicMenuShowPreparationTime             Boolean                   @default(false)
  publicMenuShowAllergenNotice              Boolean                   @default(true)
  publicOrderAutoAccept                     Boolean                   @default(false)
  // QR ordering settings
  qrOrderRequiresCustomerName               Boolean                   @default(false)
  qrOrderRequiresPhone                      Boolean                   @default(false)
  qrOrderRequiresWaiterApproval             Boolean                   @default(true)
  qrOrderAllowsAdditionalItems              Boolean                   @default(true)
  // Public reservation settings
  publicReservationAutoConfirm              Boolean                   @default(false)
  publicReservationMaximumPartySize         Int?
  publicReservationMinimumLeadMinutes       Int                       @default(60)
  publicReservationMaximumDaysAhead         Int                       @default(90)
  publicReservationRequireDiningArea        Boolean                   @default(false)
  publicReservationAllowTableSelection      Boolean                   @default(false)
  // Order capacity settings
  publicMaximumActiveOrders                 Int?
  publicMaximumOrdersPerTimeSlot            Int?
  publicOrderSlotMinutes                    Int                       @default(15)
  publicMaximumAdvanceOrderDays             Int                       @default(7)
  publicPauseOrdering                       Boolean                   @default(false)
  publicPauseOrderingReason                 String?
  createdAt                                 DateTime                  @default(now())
  updatedAt                                 DateTime                  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model User {
  id                  String     @id @default(uuid())
  restaurantId        String
  firstName           String
  lastName            String
  email               String     @unique
  phone               String?
  employeeCode        String?
  passwordHash        String
  status              UserStatus @default(ACTIVE)
  mustChangePassword  Boolean    @default(false)
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  restaurant                         Restaurant                          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  roles                              UserRole[]
  auditLogs                          AuditLog[]
  stockMovements                     StockMovement[]                     @relation("actorStockMovements")
  attributedStockMovements           StockMovement[]                     @relation("waiterStockMovements")
  ordersAsWaiter                     Order[]                             @relation("waiterOrders")
  assignedTables                     RestaurantTable[]                   @relation("waiterAssignedTables")
  ordersAsClosedBy                   Order[]                             @relation("closedOrders")
  ordersAsCreatedBy                  Order[]                             @relation("createdOrders")
  ordersAsCancelledBy                Order[]                             @relation("cancelledOrders")
  paymentRequestedOrders             Order[]                             @relation("orderPaymentRequests")
  paymentsReceived                   Payment[]                           @relation("receivedPayments")
  paymentsVoided                     Payment[]                           @relation("voidedPayments")
  receiptsIssued                     Receipt[]                           @relation("issuedReceipts")
  receiptsVoided                     Receipt[]                           @relation("voidedReceipts")
  refundRequestsCreated              RefundRequest[]                     @relation("requestedRefunds")
  refundRequestsApproved             RefundRequest[]                     @relation("approvedRefunds")
  refundRequestsRejected             RefundRequest[]                     @relation("rejectedRefunds")
  paymentRequests                    PaymentRequest[]                    @relation("requestedPayments")
  paymentRequestCancellers           PaymentRequest[]                    @relation("cancelledPayments")
  refreshTokens                      RefreshToken[]
  notifications                      AppNotification[]                   @relation("userNotifications")
  notificationPreferences            NotificationPreference[]            @relation("userNotificationPreferences")
  approvalRequestsCreated            ApprovalRequest[]                   @relation("approvalRequestedBy")
  approvalRequestsReviewed           ApprovalRequest[]                   @relation("approvalReviewedBy")
  ticketsAssigned                    KitchenTicket[]                     @relation("assignedChefTickets")
  shiftAssignments                   ShiftAssignment[]
  attendanceEvents                   AttendanceEvent[]
  employeeBreaksStarted              EmployeeBreak[]                     @relation("breakStarters")
  employeeBreaksEnded                EmployeeBreak[]                     @relation("breakEnders")
  openedShifts                       WorkShift[]                         @relation("openedWorkShifts")
  closedShifts                       WorkShift[]                         @relation("closedWorkShifts")
  cancelledShifts                    WorkShift[]                         @relation("cancelledWorkShifts")
  createdShifts                      WorkShift[]                         @relation("createdWorkShifts")
  cashierSessionsOpened              CashierSession[]                    @relation("cashierSessions")
  sessionsOpened                     CashierSession[]                    @relation("openedSessions")
  cashierSessionsApproved            CashierSession[]                    @relation("approvedSessions")
  cashierSessionsRejected            CashierSession[]                    @relation("rejectedSessions")
  cashierSessionsClosed              CashierSession[]                    @relation("closedSessions")
  cashDrawerMovements                CashDrawerMovement[]
  cashDrawerMovementsApproved        CashDrawerMovement[]                @relation("approvedDrawerMovements")
  shiftHandoversFrom                 ShiftHandover[]                     @relation("handoverFrom")
  shiftHandoversTo                   ShiftHandover[]                     @relation("handoverTo")
  shiftHandoversAcknowledged         ShiftHandover[]                     @relation("handoverAcknowledged")
  shiftExceptionsRaised              ShiftException[]                    @relation("raisedExceptions")
  orderItemCancellers                OrderItem[]                         @relation("cancelledOrderItems")
  correctedAssignments               ShiftAssignment[]                   @relation("correctedAssignments")
  shiftExceptionsReviewed            ShiftException[]                    @relation("reviewedExceptions")
  // Phase 8: Customer relations
  customersCreated                   Customer[]                          @relation("customerCreatedBy")
  customerNotesCreated               CustomerNote[]                      @relation("customerNoteCreatedBy")
  // Phase 8: Reservation relations
  reservationsConfirmed              Reservation[]                       @relation("reservationConfirmedBy")
  reservationsCheckedIn              Reservation[]                       @relation("reservationCheckedInBy")
  reservationsSeated                 Reservation[]                       @relation("reservationSeatedBy")
  reservationsCancelled              Reservation[]                       @relation("reservationCancelledBy")
  reservationsNoShowMarked           Reservation[]                       @relation("reservationNoShowMarkedBy")
  reservationsCreated                Reservation[]                       @relation("reservationCreatedBy")
  reservationStatusHistory           ReservationStatusHistory[]          @relation("statusHistoryChangedBy")
  // Phase 8: Waiting list relations
  waitingListCreated                 WaitingListEntry[]                  @relation("waitingListCreatedBy")
  waitingListUpdated                 WaitingListEntry[]                  @relation("waitingListUpdatedBy")
  // Phase 8: Promotion relations
  promotionsCreated                  Promotion[]                         @relation("promotionCreatedBy")
  promotionUsageCreated              PromotionUsage[]                    @relation("promotionUsageCreatedBy")
  // Phase 8: Discount relations
  discountsApplied                   OrderDiscount[]                     @relation("discountAppliedBy")
  discountsApproved                  OrderDiscount[]                     @relation("discountApprovedBy")
  discountRequestsCreated            DiscountRequest[]                   @relation("discountRequestRequestedBy")
  discountRequestsReviewed           DiscountRequest[]                   @relation("discountRequestReviewedBy")
  // Phase 9: Import & UAT relations
  importJobsRequested                ImportJob[]                         @relation("importJobRequestedBy")
  uatAssignedScenarios               UATScenario[]                       @relation("uatAssignedTo")
  uatTestedScenarios                 UATScenario[]                       @relation("uatTestedBy")
  PublicOrderCancellationRequest     PublicOrderCancellationRequest[]
  // Phase 13
  employmentProfiles                 EmployeeEmploymentProfile[]
  // Phase 13
  compensationProfiles               EmployeeCompensationProfile[]       @relation("compensationUser")
  serviceChargeAllocations           ServiceChargeAllocation[]
  serviceChargePools                 ServiceChargePool[]                 @relation("userServiceChargePool")
  tipPoolAllocations                 TipPoolAllocation[]
  tipPools                           TipPool[]                           @relation("userTipPool")
  customerTips                       CustomerTip[]                       @relation("userCustomerTip")
  staffAdvanceRepayments             StaffAdvanceRepayment[]
  staffAdvances                      StaffAdvance[]
  payslips                           Payslip[]
  payrollDisbursements               PayrollDisbursement[]
  payrollApprovals                   PayrollApproval[]                   @relation("userPayrollApproval")
  payrollEmployeeLines               PayrollEmployeeLine[]
  payrollRuns                        PayrollRun[]                        @relation("userPayrollRun")
  employeeRecurringPayrollComponents EmployeeRecurringPayrollComponent[]
  overtimeApprovals                  OvertimeApproval[]
  leaveApprovals                     LeaveApproval[]                     @relation("userLeaveApproval")
  leaveRequests                      LeaveRequest[]
  leaveLedgerTransactions            LeaveLedgerTransaction[]
  employeeLeaveBalances              EmployeeLeaveBalance[]

  compensationCreatedBy       EmployeeCompensationProfile[]       @relation("compensationCreatedBy")
  compensationApprovedBy      EmployeeCompensationProfile[]       @relation("compensationApprovedBy")
  ledgerCreatedBy             LeaveLedgerTransaction[]            @relation("ledgerCreatedBy")
  leaveApprovedBy             LeaveRequest[]                      @relation("leaveApprovedBy")
  leaveRejectedBy             LeaveRequest[]                      @relation("leaveRejectedBy")
  leaveCancelledBy            LeaveRequest[]                      @relation("leaveCancelledBy")
  leaveApprovalRequestedBy    LeaveApproval[]                     @relation("leaveApprovalRequestedBy")
  leaveApprovalReviewedBy     LeaveApproval[]                     @relation("leaveApprovalReviewedBy")
  overtimeRequestedBy         OvertimeApproval[]                  @relation("overtimeRequestedBy")
  overtimeReviewedBy          OvertimeApproval[]                  @relation("overtimeReviewedBy")
  recurringComponentCreatedBy EmployeeRecurringPayrollComponent[] @relation("recurringComponentCreatedBy")
  payrollRunCreatedBy         PayrollRun[]                        @relation("payrollRunCreatedBy")
  payrollRunCalculatedBy      PayrollRun[]                        @relation("payrollRunCalculatedBy")
  payrollRunApprovedBy        PayrollRun[]                        @relation("payrollRunApprovedBy")
  payrollRunFinalizedBy       PayrollRun[]                        @relation("payrollRunFinalizedBy")
  payrollLineApprovedBy       PayrollEmployeeLine[]               @relation("payrollLineApprovedBy")
  payrollApprovalRequestedBy  PayrollApproval[]                   @relation("payrollApprovalRequestedBy")
  payrollApprovalReviewedBy   PayrollApproval[]                   @relation("payrollApprovalReviewedBy")
  disbursementPostedBy        PayrollDisbursement[]               @relation("disbursementPostedBy")
  disbursementReversedBy      PayrollDisbursement[]               @relation("disbursementReversedBy")
  payslipIssuedBy             Payslip[]                           @relation("payslipIssuedBy")
  payslipVoidedBy             Payslip[]                           @relation("payslipVoidedBy")
  advanceRequestedBy          StaffAdvance[]                      @relation("advanceRequestedBy")
  advanceApprovedBy           StaffAdvance[]                      @relation("advanceApprovedBy")
  advanceRejectedBy           StaffAdvance[]                      @relation("advanceRejectedBy")
  advanceDisbursedBy          StaffAdvance[]                      @relation("advanceDisbursedBy")
  advanceWrittenOffBy         StaffAdvance[]                      @relation("advanceWrittenOffBy")
  repaymentRecordedBy         StaffAdvanceRepayment[]             @relation("repaymentRecordedBy")
  repaymentReversedBy         StaffAdvanceRepayment[]             @relation("repaymentReversedBy")
  tipRecordedBy               CustomerTip[]                       @relation("tipRecordedBy")
  tipReversedBy               CustomerTip[]                       @relation("tipReversedBy")
  tipDirectRecipient          CustomerTip[]                       @relation("tipDirectRecipient")
  tipPoolCreatedBy            TipPool[]                           @relation("tipPoolCreatedBy")
  tipPoolCalculatedBy         TipPool[]                           @relation("tipPoolCalculatedBy")
  tipPoolApprovedBy           TipPool[]                           @relation("tipPoolApprovedBy")
  scPoolCreatedBy             ServiceChargePool[]                 @relation("scPoolCreatedBy")
  scPoolCalculatedBy          ServiceChargePool[]                 @relation("scPoolCalculatedBy")
  scPoolApprovedBy            ServiceChargePool[]                 @relation("scPoolApprovedBy")
  printJobs                   PrintJob[]

  @@index([restaurantId])
  @@index([email])
  @@index([employeeCode])
  @@index([status])
}

model Role {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isSystemRole Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users UserRole[]
}

model UserRole {
  userId       String
  roleId       String
  assignedAt   DateTime @default(now())
  assignedById String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

// ==========================================
// REFRESH TOKENS (Phase 1)
// ==========================================

model RefreshToken {
  id           String    @id @default(uuid())
  restaurantId String
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  userAgent    String?
  ipAddress    String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([restaurantId])
}

// ==========================================
// AUDIT
// ==========================================

model AuditLog {
  id            String   @id @default(uuid())
  restaurantId  String
  userId        String?
  action        String
  entityType    String
  entityId      String?
  description   String?
  // Change tracking (replaces metadata)
  previousValue Json?
  newValue      Json?
  // Keep metadata for backward compatibility
  metadata      Json?
  // Severity for filtering: INFO, WARNING, ERROR, CRITICAL
  severity       String   @default("INFO")
  // Tamper-resistant hash chain (computed on create, can be backfilled for existing rows)
  hash          String?
  previousHash  String?
  // Source details
  ipAddress     String?
  userAgent     String?
  requestMethod String?
  requestPath   String?
  correlationId String?
  createdAt     DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@index([restaurantId, createdAt])
  @@index([restaurantId, action])
  @@index([restaurantId, entityType])
  @@index([restaurantId, userId])
  @@index([restaurantId, severity])
  @@index([createdAt])
}

// ==========================================
// SYSTEM MONITORING & METRICS
// ==========================================

model SystemMetric {
  id           String   @id @default(uuid())
  restaurantId String?
  metricType   String   // e.g. 'CPU', 'MEMORY', 'DB_QUERY_TIME', 'API_LATENCY', 'SOCKET_CONNECTIONS', 'ACTIVE_USERS'
  metricName   String
  metricValue  Float
  unit         String   @default("ms")
  tags         Json?
  recordedAt   DateTime @default(now())

  @@index([metricType, recordedAt])
  @@index([restaurantId, metricType, recordedAt])
  @@index([recordedAt])
}

model SlowQueryLog {
  id           String   @id @default(uuid())
  restaurantId String?
  query        String
  durationMs   Float
  source       String?  // e.g. route name or service name
  correlationId String?
  params       Json?
  recordedAt   DateTime @default(now())

  @@index([durationMs])
  @@index([recordedAt])
  @@index([source])
}

model ApprovalRequest {
  id              String                @id @default(uuid())
  restaurantId    String
  requestType     ApprovalRequestType
  status          ApprovalRequestStatus @default(PENDING)
  title           String
  description     String?
  entityType      String?
  entityId        String?
  payload         Json
  requestedById   String
  reviewedById    String?
  requestedAt     DateTime              @default(now())
  reviewedAt      DateTime?
  rejectionReason String?
  decisionNote    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  requestedBy User       @relation("approvalRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?      @relation("approvalReviewedBy", fields: [reviewedById], references: [id])

  @@index([restaurantId])
  @@index([requestType])
  @@index([status])
  @@index([entityType, entityId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([createdAt])
}

// ==========================================
// DINING & TABLES (Phase 2)
// ==========================================

model DiningArea {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  tables           RestaurantTable[]
  customers        Customer[]         @relation("customerPreferredDiningArea")
  reservations     Reservation[]
  WaitingListEntry WaitingListEntry[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model RestaurantTable {
  id           String      @id @default(uuid())
  restaurantId String
  diningAreaId String?
  name         String
  code         String
  capacity     Int
  shape        TableShape  @default(ROUND)
  status       TableStatus @default(AVAILABLE)
  positionX    Int?
  positionY    Int?
  displayOrder Int         @default(0)
  isActive     Boolean     @default(true)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignedWaiterId String?

  restaurant         Restaurant         @relation(fields: [restaurantId], references: [id])
  diningArea         DiningArea?        @relation(fields: [diningAreaId], references: [id])
  assignedWaiter     User?              @relation("waiterAssignedTables", fields: [assignedWaiterId], references: [id])
  orders             Order[]
  customers          Customer[]         @relation("customerPreferredTable")
  waitingListEntries WaitingListEntry[]
  reservations       Reservation[]
  TableQrToken       TableQrToken[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([diningAreaId])
  @@index([status])
  @@index([isActive])
}

// ==========================================
// MENU (Phase 2)
// ==========================================

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant              Restaurant              @relation(fields: [restaurantId], references: [id])
  items                   MenuItem[]
  promotionMenuCategories PromotionMenuCategory[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model KitchenStation {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  menuItems  MenuItem[]
  tickets    KitchenTicket[]
  printers   Printer[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model MenuItem {
  id                     String       @id @default(uuid())
  restaurantId           String
  categoryId             String?
  kitchenStationId       String?
  name                   String
  code                   String
  description            String?
  itemType               MenuItemType @default(FOOD)
  price                  Decimal
  costPrice              Decimal?
  taxRate                Decimal      @default(0)
  preparationTimeMinutes Int?
  requiresPreparation    Boolean      @default(true)
  trackInventory         Boolean      @default(false)
  isAvailable            Boolean      @default(true)
  isActive               Boolean      @default(true)
  imageUrl               String?
  displayOrder           Int          @default(0)
  // Phase 10: Public menu fields
  publicDescription      String?
  publicImageUrl         String?
  isFeatured             Boolean      @default(false)
  isPubliclyVisible      Boolean      @default(true)
  dietaryLabels          String?
  allergenInformation    String?
  publicSortOrder        Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  restaurant            Restaurant                     @relation(fields: [restaurantId], references: [id])
  category              MenuCategory?                  @relation(fields: [categoryId], references: [id])
  kitchenStation        KitchenStation?                @relation(fields: [kitchenStationId], references: [id])
  orderItems            OrderItem[]
  availabilitySchedules MenuItemAvailabilitySchedule[]
  recipes               Recipe[]
  promotionMenuItems    PromotionMenuItem[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([kitchenStationId])
  @@index([isAvailable])
  @@index([isActive])
  @@index([itemType])
}

model MenuItemAvailabilitySchedule {
  id         String    @id @default(uuid())
  menuItemId String
  dayOfWeek  DayOfWeek
  startTime  String // HH:mm format
  endTime    String // HH:mm format
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, dayOfWeek, startTime])
  @@index([menuItemId])
}

// ==========================================
// ORDERS (Phase 3)
// ==========================================

model Order {
  id                   String             @id @default(uuid())
  restaurantId         String
  orderNumber          String
  orderType            OrderType          @default(DINE_IN)
  status               OrderStatus        @default(DRAFT)
  paymentStatus        OrderPaymentStatus @default(UNPAID)
  tableId              String?
  guestCount           Int?
  customerName         String?
  customerPhone        String?
  notes                String?
  subtotal             Decimal            @default(0)
  taxAmount            Decimal            @default(0)
  serviceCharge        Decimal            @default(0)
  discountAmount       Decimal            @default(0)
  totalAmount          Decimal            @default(0)
  amountPaid           Decimal            @default(0)
  amountDue            Decimal            @default(0)
  submittedAt          DateTime?
  preparationStartedAt DateTime?
  readyAt              DateTime?
  servedAt             DateTime?
  paymentRequestedAt   DateTime?
  paymentRequestedById String?
  cancelledAt          DateTime?
  cancelledById        String?
  cancellationReason   String?
  closedAt             DateTime?
  closedById           String?
  createdById          String
  waiterId             String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  restaurant                     Restaurant                       @relation(fields: [restaurantId], references: [id])
  table                          RestaurantTable?                 @relation(fields: [tableId], references: [id])
  paymentRequestedBy             User?                            @relation("orderPaymentRequests", fields: [paymentRequestedById], references: [id])
  cancelledBy                    User?                            @relation("cancelledOrders", fields: [cancelledById], references: [id])
  closedBy                       User?                            @relation("closedOrders", fields: [closedById], references: [id])
  createdBy                      User                             @relation("createdOrders", fields: [createdById], references: [id])
  waiter                         User                             @relation("waiterOrders", fields: [waiterId], references: [id])
  items                          OrderItem[]
  payments                       Payment[]
  refundRequests                 RefundRequest[]
  receipts                       Receipt[]
  paymentRequests                PaymentRequest[]
  kitchenTickets                 KitchenTicket[]
  customerId                     String?
  totalBeforeDiscount            Decimal                          @default(0)
  loyaltyPointsEarned            Int                              @default(0)
  loyaltyPointsRedeemed          Int                              @default(0)
  loyaltyRedemptionValue         Decimal                          @default(0)
  notifications                  AppNotification[]
  orderDiscounts                 OrderDiscount[]
  promotionUsages                PromotionUsage[]
  loyaltyTransactions            LoyaltyTransaction[]
  reservations                   Reservation[]
  DiscountRequest                DiscountRequest[]
  // Phase 10: Public order fields
  publicReference                String?                          @unique
  publicAccessTokenHash          String?
  publicOrderStatus              PublicOrderStatus?
  publicOrderSource              PublicOrderSource?
  customerEmailSnapshot          String?
  pickupTimeRequested            DateTime?
  deliveryAddressId              String?
  deliveryAddressSnapshot        Json?
  deliveryZoneId                 String?
  deliveryFee                    Decimal                          @default(0)
  deliveryInstructions           String?
  publicOrderNotes               String?
  acceptedAt                     DateTime?
  acceptedById                   String?
  rejectedAt                     DateTime?
  rejectedById                   String?
  rejectionReason                String?
  dispatchedAt                   DateTime?
  deliveredAt                    DateTime?
  deliveryAssignedToId           String?
  publicPaymentChoice            PublicPaymentChoice?
  manualPaymentProvider          String?
  manualPaymentReference         String?
  PublicOrderCancellationRequest PublicOrderCancellationRequest[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([paymentStatus])
  @@index([waiterId])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, closedAt])
  @@index([restaurantId, waiterId, closedAt])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, paymentStatus, createdAt])
  @@index([restaurantId, tableId, closedAt])
  @@index([restaurantId, publicOrderStatus])
}

model OrderItem {
  id                   String          @id @default(uuid())
  orderId              String
  menuItemId           String
  kitchenStationId     String?
  menuItemNameSnapshot String
  menuItemCodeSnapshot String
  itemTypeSnapshot     MenuItemType    @default(FOOD)
  unitPrice            Decimal
  taxRate              Decimal         @default(0)
  quantity             Int
  lineSubtotal         Decimal
  lineTaxAmount        Decimal         @default(0)
  lineTotal            Decimal
  specialInstructions  String?
  requiresPreparation  Boolean         @default(true)
  status               OrderItemStatus @default(DRAFT)
  submittedAt          DateTime?
  acceptedAt           DateTime?
  preparationStartedAt DateTime?
  readyAt              DateTime?
  servedAt             DateTime?
  cancelledAt          DateTime?
  cancelledById        String?
  cancellationReason   String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  order                   Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem                MenuItem           @relation(fields: [menuItemId], references: [id])
  cancelledBy             User?              @relation("cancelledOrderItems", fields: [cancelledById], references: [id])
  kitchenTicketItem       KitchenTicketItem?
  lineDiscountAmount      Decimal            @default(0)
  lineTotalBeforeDiscount Decimal            @default(0)
  OrderDiscount           OrderDiscount[]
  DiscountRequest         DiscountRequest[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([kitchenStationId])
  @@index([status])
  @@index([menuItemId, createdAt])
  @@index([status, createdAt])
}

// ==========================================
// KITCHEN TICKETS (Phase 3)
// ==========================================

model KitchenTicket {
  id                   String              @id @default(uuid())
  restaurantId         String
  orderId              String
  kitchenStationId     String
  ticketNumber         String
  status               KitchenTicketStatus @default(NEW)
  assignedChefId       String?
  createdAt            DateTime            @default(now())
  acceptedAt           DateTime?
  preparationStartedAt DateTime?
  readyAt              DateTime?
  cancelledAt          DateTime?
  updatedAt            DateTime            @updatedAt

  restaurant     Restaurant          @relation(fields: [restaurantId], references: [id])
  order          Order               @relation(fields: [orderId], references: [id])
  kitchenStation KitchenStation      @relation(fields: [kitchenStationId], references: [id])
  assignedChef   User?               @relation("assignedChefTickets", fields: [assignedChefId], references: [id])
  items          KitchenTicketItem[]

  @@unique([restaurantId, ticketNumber])
  @@index([restaurantId])
  @@index([orderId])
  @@index([kitchenStationId])
  @@index([status])
  @@index([createdAt])
  @@index([restaurantId, kitchenStationId, createdAt])
  @@index([restaurantId, status, createdAt])
  @@index([assignedChefId, createdAt])
}

model KitchenTicketItem {
  id              String   @id @default(uuid())
  kitchenTicketId String
  orderItemId     String   @unique
  createdAt       DateTime @default(now())

  kitchenTicket KitchenTicket @relation(fields: [kitchenTicketId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id])

  @@index([kitchenTicketId])
  @@index([orderItemId])
}

// ==========================================
// NOTIFICATIONS (Phase 3)
// ==========================================

model AppNotification {
  id           String           @id @default(uuid())
  restaurantId String
  userId       String
  type         NotificationType
  title        String
  message      String?
  orderId      String?
  entityType   String?
  entityId     String?
  isRead       Boolean          @default(false)
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  order      Order?     @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation("userNotifications", fields: [userId], references: [id])

  @@index([userId])
  @@index([restaurantId])
  @@index([isRead])
  @@index([createdAt])
  @@index([orderId])
}

model NotificationPreference {
  id           String                         @id @default(uuid())
  restaurantId String
  userId       String
  category     NotificationPreferenceCategory
  inAppEnabled Boolean                        @default(true)
  soundEnabled Boolean                        @default(true)
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation("userNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([restaurantId])
  @@index([userId])
  @@index([category])
}

// ==========================================
// PAYMENT (Phase 5)
// ==========================================

model Payment {
  id               String                 @id @default(uuid())
  restaurantId     String
  orderId          String
  paymentNumber    String
  transactionType  PaymentTransactionType @default(PAYMENT)
  method           PaymentMethod
  status           PaymentStatus          @default(PENDING)
  amount           Decimal
  amountTendered   Decimal?
  changeAmount     Decimal                @default(0)
  referenceNumber  String?
  providerName     String?
  notes            String?
  receivedById     String
  parentPaymentId  String?
  idempotencyKey   String?
  cashierSessionId String?
  completedAt      DateTime?
  failedAt         DateTime?
  voidedAt         DateTime?
  voidedById       String?
  voidReason       String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id])
  order               Order                @relation(fields: [orderId], references: [id])
  receivedBy          User                 @relation("receivedPayments", fields: [receivedById], references: [id])
  voidedBy            User?                @relation("voidedPayments", fields: [voidedById], references: [id])
  parentPayment       Payment?             @relation("childPayments", fields: [parentPaymentId], references: [id])
  childPayments       Payment[]            @relation("childPayments")
  refundRequests      RefundRequest[]
  receiptPayments     ReceiptPayment[]
  cashierSession      CashierSession?      @relation(fields: [cashierSessionId], references: [id])
  cashDrawerMovements CashDrawerMovement[]

  @@unique([restaurantId, paymentNumber])
  @@index([idempotencyKey])
  @@index([restaurantId])
  @@index([orderId])
  @@index([method])
  @@index([status])
  @@index([transactionType])
  @@index([receivedById])
  @@index([completedAt])
  @@index([createdAt])
  @@index([cashierSessionId])
  @@index([restaurantId, completedAt])
  @@index([restaurantId, method, completedAt])
  @@index([restaurantId, receivedById, completedAt])
  @@index([restaurantId, status, transactionType, completedAt])
}

// ==========================================
// RECEIPTS (Phase 5)
// ==========================================

model Receipt {
  id                        String        @id @default(uuid())
  restaurantId              String
  orderId                   String
  receiptNumber             String
  status                    ReceiptStatus @default(ISSUED)
  currency                  String
  restaurantNameSnapshot    String
  restaurantEmailSnapshot   String?
  restaurantPhoneSnapshot   String?
  restaurantAddressSnapshot String?
  restaurantLogoUrlSnapshot String?
  orderNumberSnapshot       String
  orderTypeSnapshot         String
  tableNameSnapshot         String?
  tableCodeSnapshot         String?
  waiterNameSnapshot        String
  customerNameSnapshot      String?
  customerPhoneSnapshot     String?
  subtotal                  Decimal
  taxAmount                 Decimal
  serviceChargeAmount       Decimal
  discountAmount            Decimal
  totalAmount               Decimal
  tipAmount                 Decimal       @default(0)
  amountPaid                Decimal
  changeAmount              Decimal
  receiptFooterSnapshot     String?
  issuedById                String
  issuedAt                  DateTime      @default(now())
  voidedAt                  DateTime?
  voidedById                String?
  voidReason                String?
  reprintCount              Int           @default(0)
  lastReprintedAt           DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id])
  order      Order            @relation(fields: [orderId], references: [id])
  issuedBy   User             @relation("issuedReceipts", fields: [issuedById], references: [id])
  voidedBy   User?            @relation("voidedReceipts", fields: [voidedById], references: [id])
  lines      ReceiptLine[]
  payments   ReceiptPayment[]

  @@unique([restaurantId, receiptNumber])
  @@index([restaurantId])
  @@index([orderId])
  @@index([issuedById])
  @@index([issuedAt])
  @@index([status])
  @@index([restaurantId, issuedAt])
  @@index([restaurantId, issuedById, issuedAt])
}

model ReceiptLine {
  id                  String   @id @default(uuid())
  receiptId           String
  orderItemId         String?
  itemNameSnapshot    String
  itemCodeSnapshot    String
  quantity            Int
  unitPrice           Decimal
  lineSubtotal        Decimal
  lineTaxAmount       Decimal
  lineTotal           Decimal
  specialInstructions String?
  createdAt           DateTime @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

model ReceiptPayment {
  id              String        @id @default(uuid())
  receiptId       String
  paymentId       String
  method          PaymentMethod
  amount          Decimal
  referenceNumber String?
  createdAt       DateTime      @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id])

  @@unique([receiptId, paymentId])
  @@index([receiptId])
  @@index([paymentId])
}

// ==========================================
// PAYMENT REQUESTS (Phase 5)
// ==========================================

model PaymentRequest {
  id            String    @id @default(uuid())
  restaurantId  String
  orderId       String
  requestedById String
  cancelledAt   DateTime?
  cancelledById String?
  createdAt     DateTime  @default(now())

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  order       Order      @relation(fields: [orderId], references: [id])
  requestedBy User       @relation("requestedPayments", fields: [requestedById], references: [id])
  cancelledBy User?      @relation("cancelledPayments", fields: [cancelledById], references: [id])

  @@unique([orderId])
  @@index([restaurantId])
  @@index([orderId])
}

// ==========================================
// REFUND REQUESTS (Phase 5)
// ==========================================

model RefundRequest {
  id              String              @id @default(uuid())
  restaurantId    String
  orderId         String
  paymentId       String
  requestedAmount Decimal
  reason          String
  requestedById   String
  approvedById    String?
  rejectedById    String?
  status          RefundRequestStatus @default(PENDING)
  requestedAt     DateTime            @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  order       Order      @relation(fields: [orderId], references: [id])
  payment     Payment    @relation(fields: [paymentId], references: [id])
  requestedBy User       @relation("requestedRefunds", fields: [requestedById], references: [id])
  approvedBy  User?      @relation("approvedRefunds", fields: [approvedById], references: [id])
  rejectedBy  User?      @relation("rejectedRefunds", fields: [rejectedById], references: [id])

  @@index([restaurantId])
  @@index([orderId])
  @@index([paymentId])
  @@index([status])
}

// ==========================================
// INVENTORY (Phase 4)
// ==========================================

model StockLocation {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  code         String
  description  String?
  locationType String?
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant             Restaurant              @relation(fields: [restaurantId], references: [id])
  inventoryBalances      InventoryBalance[]
  stockReceipts          StockReceipt[]
  stockBatches           StockBatch[]
  stockMovements         StockMovement[]
  stockReservations      StockReservation[]
  inventoryAlerts        InventoryAlert[]
  menuItemInventoryLinks MenuItemInventoryLink[]
  recipeIngredients      RecipeIngredient[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
}

model InventoryCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  inventoryItems InventoryItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
}

model InventoryItem {
  id               String        @id @default(uuid())
  restaurantId     String
  categoryId       String?
  name             String
  sku              String
  barcode          String?
  description      String?
  baseUnit         InventoryUnit
  reorderLevel     Decimal       @default(0)
  targetStockLevel Decimal?
  lastPurchaseCost Decimal?
  averageCost      Decimal?
  trackExpiry      Boolean       @default(false)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  restaurant             Restaurant              @relation(fields: [restaurantId], references: [id])
  category               InventoryCategory?      @relation(fields: [categoryId], references: [id])
  inventoryBalances      InventoryBalance[]
  stockBatches           StockBatch[]
  stockMovements         StockMovement[]
  stockReservations      StockReservation[]
  inventoryAlerts        InventoryAlert[]
  recipeIngredients      RecipeIngredient[]
  menuItemInventoryLinks MenuItemInventoryLink[]
  stockReceiptLines      StockReceiptLine[]

  @@unique([restaurantId, sku])
  @@unique([restaurantId, barcode])
  @@index([restaurantId, isActive])
  @@index([categoryId])
}

model InventoryBalance {
  id               String   @id @default(uuid())
  restaurantId     String
  inventoryItemId  String
  stockLocationId  String
  onHandQuantity   Decimal  @default(0)
  reservedQuantity Decimal  @default(0)
  updatedAt        DateTime @updatedAt

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@unique([inventoryItemId, stockLocationId])
  @@index([restaurantId])
  @@index([inventoryItemId])
  @@index([stockLocationId])
}

model Supplier {
  id            String   @id @default(uuid())
  restaurantId  String
  name          String
  supplierCode  String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  stockReceipts StockReceipt[]

  @@unique([restaurantId, supplierCode])
  @@index([restaurantId, isActive])
}

model StockReceipt {
  id                 String             @id @default(uuid())
  restaurantId       String
  receiptNumber      String
  supplierId         String?
  stockLocationId    String
  status             StockReceiptStatus @default(DRAFT)
  supplierReference  String?
  receiptDate        DateTime
  notes              String?
  subtotalCost       Decimal            @default(0)
  totalCost          Decimal            @default(0)
  createdById        String
  postedById         String?
  postedAt           DateTime?
  cancelledById      String?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  stockLocation StockLocation      @relation(fields: [stockLocationId], references: [id])
  lines         StockReceiptLine[]

  @@unique([restaurantId, receiptNumber])
  @@index([restaurantId, status])
  @@index([supplierId])
  @@index([stockLocationId])
  @@index([receiptDate])
}

model StockReceiptLine {
  id              String    @id @default(uuid())
  stockReceiptId  String
  inventoryItemId String
  quantity        Decimal
  unitCost        Decimal
  lineCost        Decimal
  batchNumber     String?
  manufactureDate DateTime?
  expiryDate      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stockReceipt  StockReceipt  @relation(fields: [stockReceiptId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([stockReceiptId])
  @@index([inventoryItemId])
}

model StockBatch {
  id                 String    @id @default(uuid())
  restaurantId       String
  inventoryItemId    String
  stockLocationId    String
  stockReceiptLineId String?
  batchNumber        String?
  expiryDate         DateTime?
  receivedQuantity   Decimal
  remainingQuantity  Decimal
  unitCost           Decimal
  receivedAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@index([inventoryItemId, stockLocationId])
  @@index([inventoryItemId, expiryDate])
  @@index([remainingQuantity])
}

model Recipe {
  id            String   @id @default(uuid())
  restaurantId  String
  menuItemId    String
  name          String
  yieldQuantity Decimal  @default(1)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id])
  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id])
  ingredients RecipeIngredient[]

  @@index([restaurantId])
  @@index([menuItemId])
}

model RecipeIngredient {
  id                String   @id @default(uuid())
  recipeId          String
  inventoryItemId   String
  stockLocationId   String?
  quantityRequired  Decimal
  wastagePercentage Decimal  @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  recipe        Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation? @relation(fields: [stockLocationId], references: [id])

  @@unique([recipeId, inventoryItemId])
  @@index([recipeId])
  @@index([inventoryItemId])
}

model MenuItemInventoryLink {
  id              String   @id @default(uuid())
  restaurantId    String
  menuItemId      String
  inventoryItemId String
  stockLocationId String?
  quantityPerSale Decimal
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation? @relation(fields: [stockLocationId], references: [id])

  @@unique([menuItemId, inventoryItemId])
  @@index([restaurantId])
  @@index([inventoryItemId])
}

model StockReservation {
  id              String                     @id @default(uuid())
  restaurantId    String
  orderId         String
  orderItemId     String
  inventoryItemId String
  stockLocationId String
  quantity        Decimal
  sourceType      StockReservationSourceType
  status          StockReservationStatus     @default(ACTIVE)
  reservedAt      DateTime                   @default(now())
  consumedAt      DateTime?
  releasedAt      DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@unique([orderItemId, inventoryItemId, stockLocationId, sourceType])
  @@index([restaurantId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([inventoryItemId])
  @@index([status])
}

model StockMovement {
  id                 String            @id @default(uuid())
  restaurantId       String
  inventoryItemId    String
  stockLocationId    String
  movementType       StockMovementType
  quantity           Decimal
  quantityBefore     Decimal
  quantityAfter      Decimal
  reservedBefore     Decimal
  reservedAfter      Decimal
  unitCost           Decimal?
  totalCost          Decimal?
  orderId            String?
  orderItemId        String?
  stockReceiptId     String?
  stockReceiptLineId String?
  stockReservationId String?
  actorUserId        String
  attributedWaiterId String?
  reason             String?
  referenceNumber    String?
  metadata           Json?
  createdAt          DateTime          @default(now())

  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id])
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockLocation    StockLocation @relation(fields: [stockLocationId], references: [id])
  actor            User          @relation("actorStockMovements", fields: [actorUserId], references: [id])
  attributedWaiter User?         @relation("waiterStockMovements", fields: [attributedWaiterId], references: [id])

  @@index([restaurantId])
  @@index([inventoryItemId])
  @@index([stockLocationId])
  @@index([movementType])
  @@index([actorUserId])
  @@index([attributedWaiterId])
  @@index([orderId])
  @@index([createdAt])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, movementType, createdAt])
  @@index([restaurantId, attributedWaiterId, createdAt])
  @@index([restaurantId, inventoryItemId, createdAt])
  @@index([restaurantId, stockLocationId, createdAt])
}

model InventoryAlert {
  id              String    @id @default(uuid())
  restaurantId    String
  inventoryItemId String
  stockLocationId String
  alertType       String
  message         String
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@index([restaurantId, isResolved])
  @@index([inventoryItemId])
  @@index([stockLocationId])
}

model DocumentSequence {
  id           String   @id @default(uuid())
  restaurantId String
  sequenceType String
  businessDate String
  currentValue Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, sequenceType, businessDate])
  @@index([restaurantId])
}

// ==========================================
// SHIFT TEMPLATES (Phase 7)
// ==========================================

model ShiftTemplate {
  id                             String   @id @default(uuid())
  restaurantId                   String
  name                           String
  code                           String
  description                    String?
  startTime                      String // HH:mm format
  endTime                        String // HH:mm format
  crossesMidnight                Boolean  @default(false)
  defaultBreakMinutes            Int      @default(0)
  lateGraceMinutes               Int      @default(10)
  earlyDepartureToleranceMinutes Int      @default(10)
  overtimeThresholdMinutes       Int      @default(30)
  colorKey                       String?
  isActive                       Boolean  @default(true)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  workShifts WorkShift[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

// ==========================================
// WORK SHIFTS (Phase 7)
// ==========================================

model WorkShift {
  id                 String      @id @default(uuid())
  restaurantId       String
  shiftTemplateId    String?
  nameSnapshot       String
  codeSnapshot       String
  businessDate       String // YYYY-MM-DD in restaurant timezone
  scheduledStartAt   DateTime
  scheduledEndAt     DateTime
  status             ShiftStatus @default(DRAFT)
  notes              String?
  openedAt           DateTime?
  openedById         String?
  closingStartedAt   DateTime?
  closedAt           DateTime?
  closedById         String?
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledById      String?
  createdById        String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id])
  shiftTemplate   ShiftTemplate?    @relation(fields: [shiftTemplateId], references: [id])
  openedBy        User?             @relation("openedWorkShifts", fields: [openedById], references: [id])
  closedBy        User?             @relation("closedWorkShifts", fields: [closedById], references: [id])
  cancelledBy     User?             @relation("cancelledWorkShifts", fields: [cancelledById], references: [id])
  createdBy       User              @relation("createdWorkShifts", fields: [createdById], references: [id])
  assignments     ShiftAssignment[]
  cashierSessions CashierSession[]
  handovers       ShiftHandover[]
  exceptions      ShiftException[]

  @@index([restaurantId])
  @@index([businessDate])
  @@index([status])
  @@index([scheduledStartAt])
  @@index([scheduledEndAt])
}

// ==========================================
// SHIFT ASSIGNMENTS (Phase 7)
// ==========================================

model ShiftAssignment {
  id                    String                @id @default(uuid())
  restaurantId          String
  workShiftId           String
  userId                String
  assignedRoleName      String
  status                ShiftAssignmentStatus @default(SCHEDULED)
  scheduledStartAt      DateTime
  scheduledEndAt        DateTime
  clockedInAt           DateTime?
  clockedOutAt          DateTime?
  totalBreakMinutes     Int                   @default(0)
  workedMinutes         Int?
  lateMinutes           Int                   @default(0)
  earlyDepartureMinutes Int                   @default(0)
  overtimeMinutes       Int                   @default(0)
  absenceReason         String?
  correctionReason      String?
  correctedById         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id])
  workShift        WorkShift         @relation(fields: [workShiftId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  correctedBy      User?             @relation("correctedAssignments", fields: [correctedById], references: [id])
  attendanceEvents AttendanceEvent[]
  employeeBreaks   EmployeeBreak[]
  cashierSessions  CashierSession[]
  exceptions       ShiftException[]

  @@unique([workShiftId, userId, assignedRoleName])
  @@index([restaurantId])
  @@index([workShiftId])
  @@index([userId])
  @@index([assignedRoleName])
  @@index([status])
  @@index([scheduledStartAt])
}

// ==========================================
// ATTENDANCE EVENTS (Phase 7)
// ==========================================

model AttendanceEvent {
  id                String                @id @default(uuid())
  restaurantId      String
  workShiftId       String?
  shiftAssignmentId String?
  userId            String
  eventType         AttendanceEventType
  eventAt           DateTime
  source            AttendanceEventSource
  note              String?
  createdById       String
  isCorrection      Boolean               @default(false)
  correctedEventId  String?
  createdAt         DateTime              @default(now())

  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  shiftAssignment ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id])

  @@index([restaurantId])
  @@index([userId])
  @@index([workShiftId])
  @@index([shiftAssignmentId])
  @@index([eventType])
  @@index([eventAt])
}

// ==========================================
// EMPLOYEE BREAKS (Phase 7)
// ==========================================

model EmployeeBreak {
  id                String    @id @default(uuid())
  restaurantId      String
  shiftAssignmentId String
  startedAt         DateTime
  endedAt           DateTime?
  durationMinutes   Int?
  startedById       String
  endedById         String?
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id])
  shiftAssignment ShiftAssignment @relation(fields: [shiftAssignmentId], references: [id])
  startedBy       User            @relation("breakStarters", fields: [startedById], references: [id])
  endedBy         User?           @relation("breakEnders", fields: [endedById], references: [id])

  @@index([shiftAssignmentId])
  @@index([startedAt])
}

// ==========================================
// CASH REGISTERS (Phase 7)
// ==========================================

model CashRegister {
  id                  String             @id @default(uuid())
  restaurantId        String
  name                String
  code                String
  locationDescription String?
  status              CashRegisterStatus @default(ACTIVE)
  isDefault           Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id])
  sessions   CashierSession[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([restaurantId, status])
}

// ==========================================
// CASHIER SESSIONS (Phase 7)
// ==========================================

model CashierSession {
  id                     String               @id @default(uuid())
  restaurantId           String
  cashRegisterId         String
  workShiftId            String?
  shiftAssignmentId      String?
  cashierId              String
  status                 CashierSessionStatus @default(OPEN)
  businessDate           String
  sessionNumber          String
  openedAt               DateTime
  openedById             String
  openingFloat           Decimal
  expectedCash           Decimal              @default(0)
  countedCash            Decimal?
  varianceAmount         Decimal?
  varianceStatus         CashVarianceStatus?
  varianceReason         String?
  closingNotes           String?
  closingStartedAt       DateTime?
  submittedForApprovalAt DateTime?
  approvedAt             DateTime?
  approvedById           String?
  rejectedAt             DateTime?
  rejectedById           String?
  rejectionReason        String?
  closedAt               DateTime?
  closedById             String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  restaurant          Restaurant              @relation(fields: [restaurantId], references: [id])
  cashRegister        CashRegister            @relation(fields: [cashRegisterId], references: [id])
  workShift           WorkShift?              @relation(fields: [workShiftId], references: [id])
  shiftAssignment     ShiftAssignment?        @relation(fields: [shiftAssignmentId], references: [id])
  cashier             User                    @relation("cashierSessions", fields: [cashierId], references: [id])
  openedBy            User                    @relation("openedSessions", fields: [openedById], references: [id])
  approvedBy          User?                   @relation("approvedSessions", fields: [approvedById], references: [id])
  rejectedBy          User?                   @relation("rejectedSessions", fields: [rejectedById], references: [id])
  closedBy            User?                   @relation("closedSessions", fields: [closedById], references: [id])
  payments            Payment[]
  cashDrawerMovements CashDrawerMovement[]
  denominationCounts  CashDenominationCount[]

  @@unique([restaurantId, sessionNumber])
  @@index([restaurantId])
  @@index([cashRegisterId])
  @@index([cashierId])
  @@index([workShiftId])
  @@index([status])
  @@index([businessDate])
  @@index([openedAt])
  @@index([closedAt])
}

// ==========================================
// CASH DRAWER MOVEMENTS (Phase 7)
// ==========================================

model CashDrawerMovement {
  id               String                 @id @default(uuid())
  restaurantId     String
  cashierSessionId String
  movementType     CashDrawerMovementType
  amount           Decimal
  paymentId        String?
  orderId          String?
  referenceNumber  String?
  reason           String?
  notes            String?
  actorUserId      String
  approvedById     String?
  occurredAt       DateTime
  createdAt        DateTime               @default(now())

  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  cashierSession CashierSession @relation(fields: [cashierSessionId], references: [id])
  payment        Payment?       @relation(fields: [paymentId], references: [id])
  actor          User           @relation(fields: [actorUserId], references: [id])
  approvedBy     User?          @relation("approvedDrawerMovements", fields: [approvedById], references: [id])

  @@index([cashierSessionId])
  @@index([movementType])
  @@index([paymentId])
  @@index([orderId])
  @@index([actorUserId])
  @@index([occurredAt])
}

// ==========================================
// CASH DENOMINATION COUNTS (Phase 7)
// ==========================================

model CashDenominationCount {
  id               String   @id @default(uuid())
  restaurantId     String
  cashierSessionId String
  denomination     Decimal
  quantity         Int
  lineTotal        Decimal
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  cashierSession CashierSession @relation(fields: [cashierSessionId], references: [id])

  @@unique([cashierSessionId, denomination])
  @@index([cashierSessionId])
  @@index([restaurantId])
}

// ==========================================
// SHIFT HANDOVERS (Phase 7)
// ==========================================

model ShiftHandover {
  id                  String         @id @default(uuid())
  restaurantId        String
  workShiftId         String
  fromUserId          String
  toUserId            String?
  assignedRoleName    String?
  status              HandoverStatus @default(DRAFT)
  title               String
  notes               String?
  unresolvedOrders    Json?
  stockConcerns       Json?
  cashConcerns        Json?
  maintenanceConcerns Json?
  submittedAt         DateTime?
  acknowledgedAt      DateTime?
  acknowledgedById    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  workShift      WorkShift  @relation(fields: [workShiftId], references: [id])
  fromUser       User       @relation("handoverFrom", fields: [fromUserId], references: [id])
  toUser         User?      @relation("handoverTo", fields: [toUserId], references: [id])
  acknowledgedBy User?      @relation("handoverAcknowledged", fields: [acknowledgedById], references: [id])

  @@index([restaurantId])
  @@index([workShiftId])
  @@index([fromUserId])
  @@index([status])
}

// ==========================================
// SHIFT EXCEPTIONS (Phase 7)
// ==========================================

model ShiftException {
  id                String    @id @default(uuid())
  restaurantId      String
  workShiftId       String
  shiftAssignmentId String?
  cashierSessionId  String?
  exceptionType     String
  amount            Decimal?
  description       String
  status            String    @default("OPEN")
  raisedById        String
  reviewedById      String?
  resolution        String?
  createdAt         DateTime  @default(now())
  reviewedAt        DateTime?

  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id])
  workShift       WorkShift        @relation(fields: [workShiftId], references: [id])
  shiftAssignment ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id])
  raisedBy        User             @relation("raisedExceptions", fields: [raisedById], references: [id])
  reviewedBy      User?            @relation("reviewedExceptions", fields: [reviewedById], references: [id])

  @@index([restaurantId])
  @@index([workShiftId])
  @@index([exceptionType])
  @@index([status])
}

// ==========================================
// IMPORT & UAT MODELS (Phase 9)
// ==========================================

enum ImportStatus {
  UPLOADED
  VALIDATED
  READY
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ImportType {
  DINING_AREAS
  TABLES
  MENU_CATEGORIES
  KITCHEN_STATIONS
  MENU_ITEMS
  INVENTORY_CATEGORIES
  STOCK_LOCATIONS
  INVENTORY_ITEMS
  SUPPLIERS
  OPENING_STOCK
  STAFF
  CUSTOMERS
}

enum UATStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
  FAILED
  BLOCKED
}

model ImportJob {
  id            String       @id @default(uuid())
  restaurantId  String
  importType    ImportType
  fileName      String
  fileHash      String?
  status        ImportStatus @default(UPLOADED)
  totalRows     Int          @default(0)
  validRows     Int          @default(0)
  invalidRows   Int          @default(0)
  warningRows   Int          @default(0)
  createdRows   Int          @default(0)
  updatedRows   Int          @default(0)
  skippedRows   Int          @default(0)
  requestedById String
  previewData   Json?
  errorSummary  Json?
  createdAt     DateTime     @default(now())
  validatedAt   DateTime?
  committedAt   DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  cancelledAt   DateTime?

  restaurant  Restaurant @relation("importJobRestaurant", fields: [restaurantId], references: [id])
  requestedBy User       @relation("importJobRequestedBy", fields: [requestedById], references: [id])

  @@index([restaurantId])
  @@index([importType])
  @@index([status])
  @@index([createdAt])
}

model UATScenario {
  id                String    @id @default(uuid())
  restaurantId      String
  scenarioKey       String
  title             String
  module            String
  roleName          String
  status            UATStatus @default(NOT_STARTED)
  assignedToId      String?
  testedById        String?
  testedAt          DateTime?
  notes             String?
  evidenceReference String?
  issueReference    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  restaurant Restaurant @relation("uatRestaurant", fields: [restaurantId], references: [id])
  assignedTo User?      @relation("uatAssignedTo", fields: [assignedToId], references: [id])
  testedBy   User?      @relation("uatTestedBy", fields: [testedById], references: [id])

  @@unique([restaurantId, scenarioKey])
  @@index([restaurantId])
  @@index([module])
  @@index([roleName])
  @@index([status])
}

// ==========================================
// PHASE 10: PUBLIC WEBSITE & ONLINE ORDERING
// ==========================================

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model RestaurantOpeningHour {
  id                   String    @id @default(uuid())
  restaurantId         String
  dayOfWeek            DayOfWeek
  isClosed             Boolean   @default(false)
  supportsPickup       Boolean   @default(true)
  supportsDelivery     Boolean   @default(false)
  supportsReservations Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id])
  periods    OpeningHourPeriod[]

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
}

model OpeningHourPeriod {
  id            String   @id @default(uuid())
  openingHourId String
  restaurantId  String
  openTime      String // HH:mm
  closeTime     String // HH:mm
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  openingHour RestaurantOpeningHour @relation(fields: [openingHourId], references: [id], onDelete: Cascade)
  restaurant  Restaurant            @relation(fields: [restaurantId], references: [id])

  @@index([openingHourId])
  @@index([restaurantId])
}

model RestaurantSpecialHour {
  id           String   @id @default(uuid())
  restaurantId String
  date         DateTime // Date only, restaurant timezone
  openTime     String?
  closeTime    String?
  isClosed     Boolean  @default(false)
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, date])
  @@index([restaurantId])
}

model DeliveryZone {
  id                       String   @id @default(uuid())
  restaurantId             String
  name                     String
  code                     String
  description              String?
  minimumOrderAmount       Decimal  @default(0)
  deliveryFee              Decimal  @default(0)
  estimatedDeliveryMinutes Int      @default(30)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])
  customerAddresses CustomerAddress[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model CustomerAddress {
  id                   String   @id @default(uuid())
  restaurantId         String
  customerId           String
  deliveryZoneId       String?
  label                String? // "Home", "Work", etc.
  recipientName        String
  phone                String
  addressLine1         String
  addressLine2         String?
  neighbourhood        String?
  city                 String
  landmark             String?
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])

  @@index([restaurantId])
  @@index([customerId])
  @@index([deliveryZoneId])
  @@index([isActive])
}

model TableQrToken {
  id           String    @id @default(uuid())
  restaurantId String
  tableId      String
  tokenHash    String
  tokenPrefix  String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  rotatedAt    DateTime?
  revokedAt    DateTime?

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  table      RestaurantTable @relation(fields: [tableId], references: [id])

  @@unique([restaurantId, tokenHash])
  @@index([restaurantId])
  @@index([tableId])
  @@index([isActive])
}

model PublicOrderCancellationRequest {
  id               String                    @id @default(uuid())
  restaurantId     String
  orderId          String
  reason           String
  status           CancellationRequestStatus @default(PENDING)
  requestedAt      DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedById     String?
  resolutionReason String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])
  resolvedBy User?      @relation(fields: [resolvedById], references: [id])

  @@index([restaurantId])
  @@index([orderId])
  @@index([status])
}

model PublicOrderIdempotencyKey {
  id             String   @id @default(uuid())
  restaurantId   String
  idempotencyKey String
  orderId        String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, idempotencyKey])
  @@index([restaurantId])
  @@index([expiresAt])
}

// ==========================================
// PHASE 8: CUSTOMER MODELS
// ==========================================

model Customer {
  id                          String                 @id @default(uuid())
  restaurantId                String
  customerNumber              String
  firstName                   String
  lastName                    String?
  phone                       String?
  email                       String?
  dateOfBirth                 DateTime?
  status                      CustomerStatus         @default(ACTIVE)
  preferredDiningAreaId       String?
  preferredTableId            String?
  dietaryPreferences          String?
  allergyNotes                String?
  generalNotes                String?
  marketingConsent            Boolean                @default(false)
  marketingConsentAt          DateTime?
  marketingConsentSource      CustomerConsentSource?
  marketingConsentWithdrawnAt DateTime?
  firstVisitAt                DateTime?
  lastVisitAt                 DateTime?
  totalVisits                 Int                    @default(0)
  createdById                 String
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id])
  createdBy           User                 @relation("customerCreatedBy", fields: [createdById], references: [id])
  preferredDiningArea DiningArea?          @relation("customerPreferredDiningArea", fields: [preferredDiningAreaId], references: [id])
  preferredTable      RestaurantTable?     @relation("customerPreferredTable", fields: [preferredTableId], references: [id])
  notes               CustomerNote[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  promotionUsages     PromotionUsage[]
  orderDiscounts      OrderDiscount[]
  Reservation         Reservation[]
  WaitingListEntry    WaitingListEntry[]
  addresses           CustomerAddress[]

  @@unique([restaurantId, customerNumber])
  @@index([restaurantId])
  @@index([customerNumber])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([lastVisitAt])
}

model CustomerNote {
  id           String           @id @default(uuid())
  restaurantId String
  customerId   String
  note         String
  noteType     CustomerNoteType @default(GENERAL)
  isImportant  Boolean          @default(false)
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])
  createdBy  User       @relation("customerNoteCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([noteType])
  @@index([createdAt])
}

// ==========================================
// PHASE 8: RESERVATION MODELS
// ==========================================

model Reservation {
  id                    String            @id @default(uuid())
  restaurantId          String
  reservationNumber     String
  customerId            String?
  customerNameSnapshot  String
  customerPhoneSnapshot String?
  customerEmailSnapshot String?
  reservationSource     ReservationSource
  reservationDate       DateTime
  startAt               DateTime
  expectedEndAt         DateTime
  partySize             Int
  diningAreaId          String?
  tableId               String?
  status                ReservationStatus @default(PENDING)
  specialRequests       String?
  dietaryNotesSnapshot  String?
  occasion              String?
  internalNotes         String?
  confirmationCode      String?
  confirmedAt           DateTime?
  confirmedById         String?
  checkedInAt           DateTime?
  checkedInById         String?
  seatedAt              DateTime?
  seatedById            String?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelledById         String?
  cancellationReason    String?
  noShowMarkedAt        DateTime?
  noShowMarkedById      String?
  orderId               String?
  createdById           String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  restaurant       Restaurant                 @relation(fields: [restaurantId], references: [id])
  customer         Customer?                  @relation(fields: [customerId], references: [id])
  diningArea       DiningArea?                @relation(fields: [diningAreaId], references: [id])
  table            RestaurantTable?           @relation(fields: [tableId], references: [id])
  confirmedBy      User?                      @relation("reservationConfirmedBy", fields: [confirmedById], references: [id])
  checkedInBy      User?                      @relation("reservationCheckedInBy", fields: [checkedInById], references: [id])
  seatedBy         User?                      @relation("reservationSeatedBy", fields: [seatedById], references: [id])
  cancelledBy      User?                      @relation("reservationCancelledBy", fields: [cancelledById], references: [id])
  noShowMarkedBy   User?                      @relation("reservationNoShowMarkedBy", fields: [noShowMarkedById], references: [id])
  order            Order?                     @relation(fields: [orderId], references: [id])
  createdBy        User                       @relation("reservationCreatedBy", fields: [createdById], references: [id])
  statusHistory    ReservationStatusHistory[]
  WaitingListEntry WaitingListEntry[]

  @@unique([restaurantId, reservationNumber])
  @@index([restaurantId])
  @@index([reservationDate])
  @@index([startAt])
  @@index([status])
  @@index([customerId])
  @@index([diningAreaId])
  @@index([tableId])
  @@index([orderId])
}

model ReservationStatusHistory {
  id             String             @id @default(uuid())
  reservationId  String
  previousStatus ReservationStatus?
  newStatus      ReservationStatus
  reason         String?
  changedById    String
  changedAt      DateTime           @default(now())

  reservation  Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  changedBy    User        @relation("statusHistoryChangedBy", fields: [changedById], references: [id])
  Restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?

  @@index([reservationId])
  @@index([changedAt])
}

model WaitingListEntry {
  id                    String            @id @default(uuid())
  restaurantId          String
  queueNumber           String
  customerId            String?
  customerName          String
  phone                 String?
  partySize             Int
  priority              Int               @default(0)
  preferredDiningAreaId String?
  estimatedWaitMinutes  Int?
  status                WaitingListStatus @default(WAITING)
  joinedAt              DateTime          @default(now())
  notifiedAt            DateTime?
  seatedAt              DateTime?
  leftAt                DateTime?
  cancelledAt           DateTime?
  tableId               String?
  reservationId         String?
  orderId               String?
  notes                 String?
  createdById           String
  updatedById           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  restaurant  Restaurant       @relation(fields: [restaurantId], references: [id])
  customer    Customer?        @relation(fields: [customerId], references: [id])
  diningArea  DiningArea?      @relation(fields: [preferredDiningAreaId], references: [id])
  table       RestaurantTable? @relation(fields: [tableId], references: [id])
  reservation Reservation?     @relation(fields: [reservationId], references: [id])
  createdBy   User             @relation("waitingListCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?            @relation("waitingListUpdatedBy", fields: [updatedById], references: [id])

  @@index([restaurantId])
  @@index([status])
  @@index([priority])
  @@index([joinedAt])
  @@index([customerId])
  @@index([tableId])
}

// ==========================================
// PHASE 8: LOYALTY MODELS
// ==========================================

model LoyaltyAccount {
  id                     String    @id @default(uuid())
  restaurantId           String
  customerId             String    @unique
  pointsBalance          Int       @default(0)
  lifetimePointsEarned   Int       @default(0)
  lifetimePointsRedeemed Int       @default(0)
  tierName               String?
  enrolledAt             DateTime  @default(now())
  isActive               Boolean   @default(true)
  lastActivityAt         DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id])
  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([isActive])
  @@index([lastActivityAt])
}

model LoyaltyTransaction {
  id                  String                 @id @default(uuid())
  restaurantId        String
  loyaltyAccountId    String
  customerId          String
  transactionType     LoyaltyTransactionType
  points              Int
  balanceBefore       Int
  balanceAfter        Int
  orderId             String?
  receiptId           String?
  promotionId         String?
  reason              String?
  referenceNumber     String
  actorUserId         String
  parentTransactionId String?
  createdAt           DateTime               @default(now())

  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  loyaltyAccount LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id])
  customer       Customer       @relation(fields: [customerId], references: [id])
  order          Order?         @relation(fields: [orderId], references: [id])

  @@unique([restaurantId, referenceNumber])
  @@index([restaurantId])
  @@index([loyaltyAccountId])
  @@index([customerId])
  @@index([orderId])
  @@index([transactionType])
  @@index([createdAt])
}

// ==========================================
// PHASE 8: PROMOTION MODELS
// ==========================================

model Promotion {
  id                    String          @id @default(uuid())
  restaurantId          String
  name                  String
  code                  String?
  description           String?
  promotionType         PromotionType
  promotionScope        PromotionScope
  status                PromotionStatus @default(DRAFT)
  percentageValue       Decimal?
  fixedAmountValue      Decimal?
  fixedItemPrice        Decimal?
  buyQuantity           Int?
  getQuantity           Int?
  minimumOrderSubtotal  Decimal?
  maximumDiscountAmount Decimal?
  startAt               DateTime
  endAt                 DateTime
  usageLimitTotal       Int?
  usageLimitPerCustomer Int?
  currentUsageCount     Int             @default(0)
  customerRequired      Boolean         @default(false)
  loyaltyMembersOnly    Boolean         @default(false)
  automaticallyApply    Boolean         @default(false)
  allowStacking         Boolean         @default(false)
  priority              Int             @default(0)
  isActive              Boolean         @default(true)
  // Phase 10: Public promotion fields
  publiclyVisible       Boolean         @default(false)
  publicDescription     String?
  publicBannerImageUrl  String?
  createdById           String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  restaurant     Restaurant              @relation(fields: [restaurantId], references: [id])
  createdBy      User                    @relation("promotionCreatedBy", fields: [createdById], references: [id])
  schedules      PromotionSchedule[]
  menuItems      PromotionMenuItem[]
  menuCategories PromotionMenuCategory[]
  usages         PromotionUsage[]
  orderDiscounts OrderDiscount[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([code])
  @@index([status])
  @@index([startAt])
  @@index([endAt])
  @@index([automaticallyApply])
  @@index([priority])
}

model PromotionSchedule {
  id          String    @id @default(uuid())
  promotionId String
  dayOfWeek   DayOfWeek
  startTime   String?
  endTime     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

model PromotionMenuItem {
  promotionId String
  menuItemId  String

  promotion    Promotion   @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  menuItem     MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  Restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?

  @@id([promotionId, menuItemId])
}

model PromotionMenuCategory {
  promotionId    String
  menuCategoryId String

  promotion    Promotion    @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  menuCategory MenuCategory @relation(fields: [menuCategoryId], references: [id], onDelete: Cascade)
  Restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id])
  restaurantId String?

  @@id([promotionId, menuCategoryId])
}

model PromotionUsage {
  id              String   @id @default(uuid())
  restaurantId    String
  promotionId     String
  customerId      String?
  orderId         String
  orderDiscountId String
  discountAmount  Decimal
  usedAt          DateTime @default(now())
  createdById     String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  promotion  Promotion  @relation(fields: [promotionId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])
  createdBy  User       @relation("promotionUsageCreatedBy", fields: [createdById], references: [id])

  @@unique([promotionId, orderId, orderDiscountId])
  @@index([promotionId])
  @@index([customerId])
  @@index([orderId])
  @@index([usedAt])
}

model OrderDiscount {
  id                      String         @id @default(uuid())
  restaurantId            String
  orderId                 String
  orderItemId             String?
  promotionId             String?
  customerId              String?
  source                  DiscountSource
  status                  DiscountStatus @default(ACTIVE)
  nameSnapshot            String
  codeSnapshot            String?
  scopeSnapshot           String
  calculationTypeSnapshot String
  percentageValueSnapshot Decimal?
  fixedValueSnapshot      Decimal?
  discountAmount          Decimal
  reason                  String?
  appliedById             String
  approvedById            String?
  appliedAt               DateTime       @default(now())
  removedAt               DateTime?
  removedById             String?
  removalReason           String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])
  orderItem  OrderItem? @relation(fields: [orderItemId], references: [id])
  promotion  Promotion? @relation(fields: [promotionId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  appliedBy  User       @relation("discountAppliedBy", fields: [appliedById], references: [id])
  approvedBy User?      @relation("discountApprovedBy", fields: [approvedById], references: [id])

  @@index([restaurantId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([promotionId])
  @@index([customerId])
  @@index([source])
  @@index([status])
  @@index([appliedAt])
}

model DiscountRequest {
  id               String                @id @default(uuid())
  restaurantId     String
  orderId          String
  orderItemId      String?
  requestedById    String
  discountType     String
  percentageValue  Decimal?
  fixedAmountValue Decimal?
  reason           String
  status           DiscountRequestStatus @default(PENDING)
  reviewedById     String?
  reviewReason     String?
  createdAt        DateTime              @default(now())
  reviewedAt       DateTime?

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  order       Order      @relation(fields: [orderId], references: [id])
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  requestedBy User       @relation("discountRequestRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?      @relation("discountRequestReviewedBy", fields: [reviewedById], references: [id])

  @@index([restaurantId])
  @@index([orderId])
  @@index([status])
  @@index([requestedById])
}

