# Restaurant POS production deployment environment.
# Copy to .env.production and replace every CHANGE_ME value before deploying.

COMPOSE_PROJECT_NAME=restaurant-pos

# Public HTTPS URL serving the frontend. This must match the browser origin.
CLIENT_URL=https://pos.example.com
ALLOWED_ORIGINS=https://pos.example.com

# PostgreSQL
POSTGRES_DB=restaurant_pos
POSTGRES_USER=restaurant_pos
POSTGRES_PASSWORD=CHANGE_ME_generate_a_long_random_database_password

# Backend database URL used by Prisma inside Docker.
DATABASE_URL=postgresql://restaurant_pos:CHANGE_ME_generate_a_long_random_database_password@postgres:5432/restaurant_pos

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_for_access_tokens
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_for_refresh_tokens

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# HTTPS-ready secure cookie settings.
COOKIE_SECURE=true
# COOKIE_DOMAIN=.example.com
TRUST_PROXY=true

# API/runtime
NODE_ENV=production
PORT=5000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
DATABASE_POOL_SIZE=10
BACKUP_DIRECTORY=/app/backups
PDF_TEMP_DIRECTORY=/app/temp
UPLOAD_DIRECTORY=/app/uploads
MAINTENANCE_MODE=false

# Optional Vite build-time API base.
# Leave unset for same-origin /api. Set only when serving API on a separate origin.
# VITE_API_URL=https://pos-api.example.com/api
