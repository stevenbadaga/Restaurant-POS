# ==========================================
# Restaurant POS — Client Production Configuration
# ==========================================
# Copy this file to .env and fill in your production values.
# Only VITE_ prefixed variables are exposed to the browser.
# Never place secrets in this file. Server-side secrets belong in server/.env.
# This file is safe to commit to version control (all values are placeholders).
# ==========================================

# --- API URL ---
# The base URL for the backend API (without /api suffix)
# Use /api when the frontend and backend share one HTTPS origin through nginx.
# Use https://pos-api.yourdomain.com/api only when serving the API on a separate origin.
VITE_API_URL=/api
